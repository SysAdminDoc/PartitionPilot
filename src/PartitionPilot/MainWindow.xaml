<Window x:Class="PartitionPilot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PartitionPilot.Views"
        Title="PartitionPilot" Width="1180" Height="780"
        Icon="Assets/AppIcon.png"
        MinWidth="960" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBgBrush}"
        Closing="Window_Closing">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="132"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelCard}" Padding="18" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="PartitionPilot"
                               Style="{StaticResource AppTitleText}"/>
                    <TextBlock Text="Windows disk operations, health checks, and image workflows"
                               Style="{StaticResource CaptionText}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Style="{StaticResource StatusBadge}" Margin="0,0,8,0">
                        <TextBlock Text="Admin session"
                                   Foreground="{DynamicResource WarningBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <Border Style="{StaticResource StatusBadge}" Margin="0,0,8,0">
                        <TextBlock Text="Logged session"
                                   Foreground="{DynamicResource SuccessBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <Button Content="{Binding ThemeLabel}"
                            Command="{Binding ToggleThemeCommand}"
                            Style="{StaticResource ToolbarButton}"
                            Margin="0"
                            Padding="8,4"
                            AutomationProperties.Name="Toggle theme"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    SelectedIndex="{Binding SelectedTabIndex}"
                    TabStripPlacement="Left"
                    BorderThickness="0"
                    Background="Transparent"
                    Margin="0,0,0,14">
            <TabItem Header="Partitions" Style="{StaticResource NavTabItem}" AutomationProperties.Name="Partitions tab">
                <views:PartitionsView DataContext="{Binding Partitions}"/>
            </TabItem>
            <TabItem Header="Disk Health" Style="{StaticResource NavTabItem}" AutomationProperties.Name="Disk Health tab">
                <views:DiskHealthView DataContext="{Binding DiskHealth}"/>
            </TabItem>
            <TabItem Header="Tools" Style="{StaticResource NavTabItem}" AutomationProperties.Name="Tools tab">
                <views:ToolsView DataContext="{Binding Tools}"/>
            </TabItem>
            <TabItem Header="Disk Images" Style="{StaticResource NavTabItem}" AutomationProperties.Name="Disk Images tab">
                <views:DiskImagesView DataContext="{Binding DiskImages}"/>
            </TabItem>
            <TabItem Header="Disk Usage" Style="{StaticResource NavTabItem}" AutomationProperties.Name="Disk Usage tab">
                <views:DiskUsageView DataContext="{Binding DiskUsage}"/>
            </TabItem>
            <TabItem Header="Disk Cloning" Style="{StaticResource NavTabItem}" AutomationProperties.Name="Disk Cloning tab">
                <views:DiskCloningView DataContext="{Binding DiskCloning}"/>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                Background="{DynamicResource LogBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Activity Log"
                                   Style="{StaticResource FieldLabelText}"/>
                        <TextBlock Text="Command output, safety checks, and operation history"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Content="Export Log"
                            Command="{Binding ExportLogCommand}"
                            Style="{StaticResource ToolbarButton}"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Padding="8,3"
                            AutomationProperties.Name="Export activity log"/>
                </Grid>

                <TextBox Grid.Row="1"
                         Text="{Binding Log.FullText, Mode=OneWay}"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12"
                         Background="Transparent"
                         Foreground="{DynamicResource SubtextBrush}"
                         BorderThickness="0"
                         Padding="0"
                         TextWrapping="Wrap"
                         TextChanged="LogBox_TextChanged"
                         AutomationProperties.Name="Activity log"/>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="{DynamicResource StatusBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,7">
            <DockPanel LastChildFill="True">
                <TextBlock Text="Status"
                           Style="{StaticResource FieldLabelText}"
                           Margin="0,0,10,0"/>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource SubtextBrush}"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           AutomationProperties.Name="Status"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
