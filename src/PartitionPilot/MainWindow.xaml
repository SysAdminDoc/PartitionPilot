<Window x:Class="PartitionPilot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PartitionPilot.Views"
        Title="PartitionPilot" Width="1180" Height="780"
        MinWidth="960" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBgBrush}"
        Closing="Window_Closing">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="132"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelCard}" Padding="16" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="PartitionPilot"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="Disk partition management for Windows"
                               Style="{StaticResource CaptionText}"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{Binding ThemeLabel}"
                            Command="{Binding ToggleThemeCommand}"
                            Style="{StaticResource ToolbarButton}"
                            Margin="0,0,10,0"
                            Padding="8,4"
                            AutomationProperties.Name="Toggle theme"/>
                    <Border Background="#182026"
                            BorderBrush="{StaticResource BorderStrongBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,6">
                        <TextBlock Text="Administrator mode"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    SelectedIndex="{Binding SelectedTabIndex}"
                    TabStripPlacement="Left"
                    BorderThickness="0"
                    Background="Transparent"
                    Margin="0,0,0,14">
            <TabItem Header="Partitions" Style="{StaticResource NavTabItem}">
                <views:PartitionsView DataContext="{Binding Partitions}"/>
            </TabItem>
            <TabItem Header="Disk Health" Style="{StaticResource NavTabItem}">
                <views:DiskHealthView DataContext="{Binding DiskHealth}"/>
            </TabItem>
            <TabItem Header="Tools" Style="{StaticResource NavTabItem}">
                <views:ToolsView DataContext="{Binding Tools}"/>
            </TabItem>
            <TabItem Header="Disk Images" Style="{StaticResource NavTabItem}">
                <views:DiskImagesView DataContext="{Binding DiskImages}"/>
            </TabItem>
            <TabItem Header="Disk Usage" Style="{StaticResource NavTabItem}">
                <views:DiskUsageView DataContext="{Binding DiskUsage}"/>
            </TabItem>
            <TabItem Header="Disk Cloning" Style="{StaticResource NavTabItem}">
                <views:DiskCloningView DataContext="{Binding DiskCloning}"/>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                Background="{StaticResource LogBgBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="Activity Log"
                               Style="{StaticResource FieldLabelText}"
                               VerticalAlignment="Center"/>
                    <Button Content="Export Log"
                            Command="{Binding ExportLogCommand}"
                            Style="{StaticResource ToolbarButton}"
                            HorizontalAlignment="Right"
                            Padding="8,3"
                            AutomationProperties.Name="Export activity log"/>
                </DockPanel>

                <TextBox Grid.Row="1"
                         Text="{Binding Log.FullText, Mode=OneWay}"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12"
                         Background="Transparent"
                         Foreground="{StaticResource SubtextBrush}"
                         BorderThickness="0"
                         Padding="0"
                         TextWrapping="Wrap"
                         TextChanged="LogBox_TextChanged"
                         AutomationProperties.Name="Activity log"/>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="{StaticResource PanelBgBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,7">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{StaticResource SubtextBrush}"
                       FontSize="12"
                       AutomationProperties.Name="Status"/>
        </Border>
    </Grid>
</Window>
