<Window x:Class="PartitionPilot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PartitionPilot.Views"
        Title="PartitionPilot" Width="1380" Height="860"
        Icon="Assets/AppIcon.png"
        MinWidth="1080" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBgBrush}"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="184"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource WindowBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="Assets/AppIcon.png"
                           Width="28"
                           Height="28"
                           Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="PartitionPilot" Style="{StaticResource ShellTitleText}"/>
                        <TextBlock Text="{Binding VersionText}"
                                   Style="{StaticResource TinyLabelText}"
                                   Margin="1,1,0,0"/>
                    </StackPanel>
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           Orientation="Horizontal"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center">
                    <Button Content="Refresh"
                            Command="{Binding RefreshCurrentCommand}"
                            Style="{StaticResource CommandBarButton}"
                            AutomationProperties.Name="Refresh current workspace"/>
                    <Button Content="Export Log"
                            Command="{Binding ExportLogCommand}"
                            Style="{StaticResource CommandBarButton}"
                            AutomationProperties.Name="Export activity log"/>
                    <Button Content="Support Bundle"
                            Command="{Binding ExportSupportBundleCommand}"
                            Style="{StaticResource CommandBarButton}"
                            ToolTip="Export a redacted diagnostic bundle for troubleshooting"
                            AutomationProperties.Name="Export support bundle"/>
                    <Button Content="{Binding ThemeLabel}"
                            Command="{Binding ToggleThemeCommand}"
                            Style="{StaticResource CommandBarButton}"
                            AutomationProperties.Name="Toggle theme"/>
                    <Button Content="Elevate"
                            Command="{Binding ElevateCommand}"
                            Style="{StaticResource CommandBarButton}"
                            Margin="0"
                            ToolTip="Re-launch as administrator for disk write operations"
                            Visibility="{Binding IsReadOnly, Converter={StaticResource BoolVis}}"
                            AutomationProperties.Name="Elevate to administrator"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource PanelBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,12">
            <UniformGrid Columns="4">
                <Border Style="{StaticResource StatusTile}">
                    <StackPanel>
                        <TextBlock Text="{Binding AdminSessionText}" Style="{StaticResource SectionTitleText}"/>
                        <TextBlock Text="{Binding AdminSessionDetail}"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatusTile}">
                    <StackPanel>
                        <TextBlock Text="{Binding SessionStateText}" Style="{StaticResource SectionTitleText}"/>
                        <TextBlock Text="{Binding SessionStateDetail}"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatusTile}">
                    <StackPanel>
                        <TextBlock Text="Activity log" Style="{StaticResource SectionTitleText}"/>
                        <TextBlock Text="{Binding Log.EntryCountText}"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatusTile}" Margin="0">
                    <StackPanel>
                        <TextBlock Text="Storage console" Style="{StaticResource SectionTitleText}"/>
                        <TextBlock Text="WMI, diskpart, PowerShell"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Border>

        <TabControl Grid.Row="2"
                    SelectedIndex="{Binding SelectedTabIndex}"
                    TabStripPlacement="Left"
                    BorderThickness="0"
                    Background="Transparent"
                    Margin="18,14,18,12">
            <TabItem Style="{StaticResource NavTabItem}" AutomationProperties.Name="Partitions tab">
                <TabItem.Header>
                    <StackPanel>
                        <TextBlock Text="Partitions" Style="{StaticResource NavTitleText}"/>
                        <TextBlock Text="Manage storage layout" Style="{StaticResource NavSubtitleText}"/>
                    </StackPanel>
                </TabItem.Header>
                <views:PartitionsView DataContext="{Binding Partitions}"/>
            </TabItem>
            <TabItem Style="{StaticResource NavTabItem}" AutomationProperties.Name="Snapshots tab">
                <TabItem.Header>
                    <StackPanel>
                        <TextBlock Text="Snapshots" Style="{StaticResource NavTitleText}"/>
                        <TextBlock Text="Recovery evidence" Style="{StaticResource NavSubtitleText}"/>
                    </StackPanel>
                </TabItem.Header>
                <views:SnapshotBrowserView DataContext="{Binding Snapshots}"/>
            </TabItem>
            <TabItem Style="{StaticResource NavTabItem}" AutomationProperties.Name="Disk Health tab">
                <TabItem.Header>
                    <StackPanel>
                        <TextBlock Text="Disk Health" Style="{StaticResource NavTitleText}"/>
                        <TextBlock Text="SMART and alignment" Style="{StaticResource NavSubtitleText}"/>
                    </StackPanel>
                </TabItem.Header>
                <views:DiskHealthView DataContext="{Binding DiskHealth}"/>
            </TabItem>
            <TabItem Style="{StaticResource NavTabItem}" AutomationProperties.Name="Tools tab">
                <TabItem.Header>
                    <StackPanel>
                        <TextBlock Text="Tools" Style="{StaticResource NavTitleText}"/>
                        <TextBlock Text="Repair and maintenance" Style="{StaticResource NavSubtitleText}"/>
                    </StackPanel>
                </TabItem.Header>
                <views:ToolsView DataContext="{Binding Tools}"/>
            </TabItem>
            <TabItem Style="{StaticResource NavTabItem}" AutomationProperties.Name="Disk Images tab">
                <TabItem.Header>
                    <StackPanel>
                        <TextBlock Text="Disk Images" Style="{StaticResource NavTitleText}"/>
                        <TextBlock Text="Mount and create VHDs" Style="{StaticResource NavSubtitleText}"/>
                    </StackPanel>
                </TabItem.Header>
                <views:DiskImagesView DataContext="{Binding DiskImages}"/>
            </TabItem>
            <TabItem Style="{StaticResource NavTabItem}" AutomationProperties.Name="Disk Usage tab">
                <TabItem.Header>
                    <StackPanel>
                        <TextBlock Text="Disk Usage" Style="{StaticResource NavTitleText}"/>
                        <TextBlock Text="Find heavy folders" Style="{StaticResource NavSubtitleText}"/>
                    </StackPanel>
                </TabItem.Header>
                <views:DiskUsageView DataContext="{Binding DiskUsage}"/>
            </TabItem>
            <TabItem Style="{StaticResource NavTabItem}" AutomationProperties.Name="Disk Cloning tab">
                <TabItem.Header>
                    <StackPanel>
                        <TextBlock Text="Disk Cloning" Style="{StaticResource NavTitleText}"/>
                        <TextBlock Text="Copy and restore images" Style="{StaticResource NavSubtitleText}"/>
                    </StackPanel>
                </TabItem.Header>
                <views:DiskCloningView DataContext="{Binding DiskCloning}"/>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3"
                Style="{StaticResource Card}"
                Padding="0"
                Margin="18,0,18,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Activity Log" Style="{StaticResource SectionTitleText}"/>
                            <TextBlock Text="Operation feedback, warnings, and exported session evidence"
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <ToggleButton Content="All"
                                          IsChecked="{Binding Log.IsAllFilter, Mode=OneWay}"
                                          Command="{Binding Log.SetFilterCommand}"
                                          CommandParameter="All"
                                          Style="{StaticResource LogFilterToggle}"
                                          Margin="0,0,6,0"/>
                            <ToggleButton Content="Info"
                                          IsChecked="{Binding Log.IsInfoFilter, Mode=OneWay}"
                                          Command="{Binding Log.SetFilterCommand}"
                                          CommandParameter="Info"
                                          Style="{StaticResource LogFilterToggle}"
                                          Margin="0,0,6,0"/>
                            <ToggleButton Content="Warning"
                                          IsChecked="{Binding Log.IsWarningFilter, Mode=OneWay}"
                                          Command="{Binding Log.SetFilterCommand}"
                                          CommandParameter="Warning"
                                          Style="{StaticResource LogFilterToggle}"
                                          Margin="0,0,6,0"/>
                            <ToggleButton Content="Error"
                                          IsChecked="{Binding Log.IsErrorFilter, Mode=OneWay}"
                                          Command="{Binding Log.SetFilterCommand}"
                                          CommandParameter="Error"
                                          Style="{StaticResource LogFilterToggle}"
                                          Margin="0,0,10,0"/>
                            <Button Content="Clear"
                                    Command="{Binding Log.ClearCommand}"
                                    Style="{StaticResource CommandBarButton}"
                                    Margin="0"
                                    AutomationProperties.Name="Clear activity log"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <ListView Grid.Row="1"
                          ItemsSource="{Binding Log.FilteredEntries}"
                          BorderThickness="0"
                          Background="Transparent"
                          AutomationProperties.Name="Activity log entries">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Time" Width="92" DisplayMemberBinding="{Binding Timestamp}"/>
                            <GridViewColumn Header="Level" Width="92" DisplayMemberBinding="{Binding Level}"/>
                            <GridViewColumn Header="Details" Width="1040" DisplayMemberBinding="{Binding Message}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Background="{DynamicResource StatusBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="18,8">
            <DockPanel LastChildFill="True">
                <TextBlock Text="{Binding VersionText}"
                           Foreground="{DynamicResource SubtextBrush}"
                           FontSize="12"
                           Margin="0,0,18,0"/>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="9"
                             Height="9"
                             Fill="{DynamicResource SuccessBrush}"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{DynamicResource SubtextBrush}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               AutomationProperties.Name="Status"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
