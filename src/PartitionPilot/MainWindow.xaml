<Window x:Class="PartitionPilot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PartitionPilot"
        xmlns:views="clr-namespace:PartitionPilot.Views"
        Title="{local:Loc AppTitle}" Width="1380" Height="860"
        Icon="Assets/AppIcon.png"
        MinWidth="1080" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBgBrush}"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="184"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource WindowBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="Assets/AppIcon.png"
                           Width="28"
                           Height="28"
                           Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="{local:Loc AppTitle}" Style="{StaticResource ShellTitleText}"/>
                        <TextBlock Text="{Binding VersionText}"
                                   Style="{StaticResource TinyLabelText}"
                                   Margin="1,1,0,0"/>
                    </StackPanel>
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           Orientation="Horizontal"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center">
                    <Button Content="{local:Loc Refresh}"
                            Command="{Binding RefreshCurrentCommand}"
                            Style="{StaticResource CommandBarButton}"
                            AutomationProperties.Name="{local:Loc Xaml_RefreshCurrentWorkspace}"/>
                    <Button Content="{local:Loc ExportLog}"
                            Command="{Binding ExportLogCommand}"
                            Style="{StaticResource CommandBarButton}"
                            AutomationProperties.Name="{local:Loc Xaml_ExportActivityLog}"/>
                    <Button Content="{local:Loc SupportBundle}"
                            Command="{Binding ExportSupportBundleCommand}"
                            Style="{StaticResource CommandBarButton}"
                            ToolTip="{local:Loc Xaml_ExportARedactedDiagnosticBundleForTroubleshooting}"
                            AutomationProperties.Name="{local:Loc Xaml_ExportSupportBundle}"/>
                    <Button Content="{local:Loc Xaml_FSSupport}"
                            Command="{Binding ShowFilesystemSupportCommand}"
                            Style="{StaticResource CommandBarButton}"
                            ToolTip="{local:Loc Xaml_ShowWhichOperationsEachFilesystemSupports}"
                            AutomationProperties.Name="{local:Loc Xaml_ShowFilesystemSupportMatrix}"/>
                    <Button Content="{Binding ThemeLabel}"
                            Command="{Binding ToggleThemeCommand}"
                            Style="{StaticResource CommandBarButton}"
                            AutomationProperties.Name="{local:Loc Xaml_ToggleTheme}"/>
                    <Button Content="{local:Loc Elevate}"
                            Command="{Binding ElevateCommand}"
                            Style="{StaticResource CommandBarButton}"
                            Margin="0"
                            ToolTip="{local:Loc ElevateTooltip}"
                            Visibility="{Binding IsReadOnly, Converter={StaticResource BoolVis}}"
                            AutomationProperties.Name="{local:Loc Xaml_ElevateToAdministrator}"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource PanelBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,12">
            <UniformGrid Columns="4">
                <Border Style="{StaticResource StatusTile}">
                    <StackPanel>
                        <TextBlock Text="{Binding AdminSessionText}" Style="{StaticResource SectionTitleText}"/>
                        <TextBlock Text="{Binding AdminSessionDetail}"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatusTile}">
                    <StackPanel>
                        <TextBlock Text="{Binding SessionStateText}" Style="{StaticResource SectionTitleText}"/>
                        <TextBlock Text="{Binding SessionStateDetail}"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatusTile}">
                    <StackPanel>
                        <TextBlock Text="{local:Loc ActivityLog}" Style="{StaticResource SectionTitleText}"/>
                        <TextBlock Text="{Binding Log.EntryCountText}"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatusTile}" Margin="0">
                    <StackPanel>
                        <TextBlock Text="{local:Loc StorageConsole}" Style="{StaticResource SectionTitleText}"/>
                        <TextBlock Text="{local:Loc StorageConsoleEngines}"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Border>

        <TabControl Grid.Row="2"
                    SelectedIndex="{Binding SelectedTabIndex}"
                    TabStripPlacement="Left"
                    BorderThickness="0"
                    Background="Transparent"
                    Margin="18,14,18,12">
            <TabItem Style="{StaticResource NavTabItem}" AutomationProperties.Name="{local:Loc Xaml_PartitionsTab}">
                <TabItem.Header>
                    <StackPanel>
                        <TextBlock Text="{local:Loc TabPartitions}" Style="{StaticResource NavTitleText}"/>
                        <TextBlock Text="{local:Loc TabPartitionsSubtitle}" Style="{StaticResource NavSubtitleText}"/>
                    </StackPanel>
                </TabItem.Header>
                <views:PartitionsView DataContext="{Binding Partitions}"/>
            </TabItem>
            <TabItem Style="{StaticResource NavTabItem}" AutomationProperties.Name="{local:Loc Xaml_SnapshotsTab}">
                <TabItem.Header>
                    <StackPanel>
                        <TextBlock Text="{local:Loc TabSnapshots}" Style="{StaticResource NavTitleText}"/>
                        <TextBlock Text="{local:Loc TabSnapshotsSubtitle}" Style="{StaticResource NavSubtitleText}"/>
                    </StackPanel>
                </TabItem.Header>
                <views:SnapshotBrowserView DataContext="{Binding Snapshots}"/>
            </TabItem>
            <TabItem Style="{StaticResource NavTabItem}" AutomationProperties.Name="{local:Loc Xaml_DiskHealthTab}">
                <TabItem.Header>
                    <StackPanel>
                        <TextBlock Text="{local:Loc TabDiskHealth}" Style="{StaticResource NavTitleText}"/>
                        <TextBlock Text="{local:Loc TabDiskHealthSubtitle}" Style="{StaticResource NavSubtitleText}"/>
                    </StackPanel>
                </TabItem.Header>
                <views:DiskHealthView DataContext="{Binding DiskHealth}"/>
            </TabItem>
            <TabItem Style="{StaticResource NavTabItem}" AutomationProperties.Name="{local:Loc Xaml_ToolsTab}">
                <TabItem.Header>
                    <StackPanel>
                        <TextBlock Text="{local:Loc TabTools}" Style="{StaticResource NavTitleText}"/>
                        <TextBlock Text="{local:Loc TabToolsSubtitle}" Style="{StaticResource NavSubtitleText}"/>
                    </StackPanel>
                </TabItem.Header>
                <views:ToolsView DataContext="{Binding Tools}"/>
            </TabItem>
            <TabItem Style="{StaticResource NavTabItem}" AutomationProperties.Name="{local:Loc Xaml_DiskImagesTab}">
                <TabItem.Header>
                    <StackPanel>
                        <TextBlock Text="{local:Loc TabDiskImages}" Style="{StaticResource NavTitleText}"/>
                        <TextBlock Text="{local:Loc TabDiskImagesSubtitle}" Style="{StaticResource NavSubtitleText}"/>
                    </StackPanel>
                </TabItem.Header>
                <views:DiskImagesView DataContext="{Binding DiskImages}"/>
            </TabItem>
            <TabItem Style="{StaticResource NavTabItem}" AutomationProperties.Name="{local:Loc Xaml_DiskUsageTab}">
                <TabItem.Header>
                    <StackPanel>
                        <TextBlock Text="{local:Loc TabDiskUsage}" Style="{StaticResource NavTitleText}"/>
                        <TextBlock Text="{local:Loc TabDiskUsageSubtitle}" Style="{StaticResource NavSubtitleText}"/>
                    </StackPanel>
                </TabItem.Header>
                <views:DiskUsageView DataContext="{Binding DiskUsage}"/>
            </TabItem>
            <TabItem Style="{StaticResource NavTabItem}" AutomationProperties.Name="{local:Loc Xaml_DiskCloningTab}">
                <TabItem.Header>
                    <StackPanel>
                        <TextBlock Text="{local:Loc TabDiskCloning}" Style="{StaticResource NavTitleText}"/>
                        <TextBlock Text="{local:Loc TabDiskCloningSubtitle}" Style="{StaticResource NavSubtitleText}"/>
                    </StackPanel>
                </TabItem.Header>
                <views:DiskCloningView DataContext="{Binding DiskCloning}"/>
            </TabItem>
            <TabItem Style="{StaticResource NavTabItem}" AutomationProperties.Name="{local:Loc Xaml_HexViewerTab}">
                <TabItem.Header>
                    <StackPanel>
                        <TextBlock Text="{local:Loc TabHexViewer}" Style="{StaticResource NavTitleText}"/>
                        <TextBlock Text="{local:Loc TabHexViewerSubtitle}" Style="{StaticResource NavSubtitleText}"/>
                    </StackPanel>
                </TabItem.Header>
                <views:HexViewerView DataContext="{Binding HexViewer}"/>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3"
                Style="{StaticResource Card}"
                Padding="0"
                Margin="18,0,18,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{local:Loc ActivityLog}" Style="{StaticResource SectionTitleText}"/>
                            <TextBlock Text="{local:Loc ActivityLogDescription}"
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <ToggleButton Content="{local:Loc All}"
                                          IsChecked="{Binding Log.IsAllFilter, Mode=OneWay}"
                                          Command="{Binding Log.SetFilterCommand}"
                                          CommandParameter="All"
                                          Style="{StaticResource LogFilterToggle}"
                                          Margin="0,0,6,0"/>
                            <ToggleButton Content="{local:Loc Info}"
                                          IsChecked="{Binding Log.IsInfoFilter, Mode=OneWay}"
                                          Command="{Binding Log.SetFilterCommand}"
                                          CommandParameter="Info"
                                          Style="{StaticResource LogFilterToggle}"
                                          Margin="0,0,6,0"/>
                            <ToggleButton Content="{local:Loc Warning}"
                                          IsChecked="{Binding Log.IsWarningFilter, Mode=OneWay}"
                                          Command="{Binding Log.SetFilterCommand}"
                                          CommandParameter="Warning"
                                          Style="{StaticResource LogFilterToggle}"
                                          Margin="0,0,6,0"/>
                            <ToggleButton Content="{local:Loc Error}"
                                          IsChecked="{Binding Log.IsErrorFilter, Mode=OneWay}"
                                          Command="{Binding Log.SetFilterCommand}"
                                          CommandParameter="Error"
                                          Style="{StaticResource LogFilterToggle}"
                                          Margin="0,0,10,0"/>
                            <Button Content="{local:Loc Clear}"
                                    Command="{Binding Log.ClearCommand}"
                                    Style="{StaticResource CommandBarButton}"
                                    Margin="0"
                                    AutomationProperties.Name="{local:Loc Xaml_ClearActivityLog}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <ListView Grid.Row="1"
                          ItemsSource="{Binding Log.FilteredEntries}"
                          BorderThickness="0"
                          Background="Transparent"
                          AutomationProperties.Name="{local:Loc Xaml_ActivityLogEntries}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="{local:Loc Xaml_Time}" Width="92" DisplayMemberBinding="{Binding Timestamp}"/>
                            <GridViewColumn Header="{local:Loc Xaml_Level}" Width="92" DisplayMemberBinding="{Binding Level}"/>
                            <GridViewColumn Header="{local:Loc Xaml_Details}" Width="1040" DisplayMemberBinding="{Binding Message}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Background="{DynamicResource StatusBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="18,8">
            <DockPanel LastChildFill="True">
                <TextBlock Text="{Binding VersionText}"
                           Foreground="{DynamicResource SubtextBrush}"
                           FontSize="12"
                           Margin="0,0,18,0"/>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="9"
                             Height="9"
                             Fill="{DynamicResource SuccessBrush}"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{DynamicResource SubtextBrush}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               AutomationProperties.Name="{local:Loc Xaml_Status}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
