<UserControl x:Class="PartitionPilot.Views.DiskHealthView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <DockPanel IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
            <Border DockPanel.Dock="Top" Style="{StaticResource PanelCard}" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Disk Health" Style="{StaticResource PageTitleText}"/>
                        <TextBlock Text="Review physical disk status, reliability telemetry, and alignment."
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Physical Disk"
                                   Style="{StaticResource FieldLabelText}"
                                   Margin="0,0,10,0"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding PhysicalDisks}"
                                  SelectedItem="{Binding SelectedDisk}"
                                  ItemTemplate="{StaticResource PhysicalDiskInfoComboTemplate}"
                                  MinWidth="420"
                                  Height="34"
                                  FontSize="13"
                                  AutomationProperties.Name="Physical disk selector"/>
                        <Button Grid.Column="2"
                                Content="Refresh"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource ToolbarButton}"
                                Margin="10,0,0,0"
                                AutomationProperties.Name="Refresh disk health"/>
                        <Button Grid.Column="3"
                                Content="{Binding MonitorButtonText}"
                                Command="{Binding ToggleMonitorCommand}"
                                Style="{StaticResource ToolbarButton}"
                                Margin="6,0,0,0"
                                AutomationProperties.Name="Toggle temperature monitoring"/>
                        <Button Grid.Column="4"
                                Content="Export Report"
                                Command="{Binding ExportReportCommand}"
                                Style="{StaticResource ToolbarButton}"
                                Margin="6,0,0,0"
                                AutomationProperties.Name="Export SMART diagnostic report"/>
                        <Button Grid.Column="5"
                                Content="Short Test"
                                Command="{Binding RunShortTestCommand}"
                                Style="{StaticResource ToolbarButton}"
                                Margin="6,0,0,0"
                                AutomationProperties.Name="Run SMART short self-test"/>
                        <Button Grid.Column="6"
                                Content="Extended Test"
                                Command="{Binding RunExtendedTestCommand}"
                                Style="{StaticResource ToolbarButton}"
                                Margin="6,0,0,0"
                                AutomationProperties.Name="Run SMART extended self-test"/>
                    </Grid>
                </Grid>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,8,0">
                    <Border MinHeight="100">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource EmptyStatePanel}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PhysicalDisks.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="No disk health data loaded" Style="{StaticResource EmptyStateTitle}"/>
                            <TextBlock Text="Refresh to load physical disk, SMART reliability, and alignment details."
                                       Style="{StaticResource EmptyStateText}"
                                       Margin="0"/>
                        </StackPanel>
                    </Border>

                    <GroupBox Header="Disk Information">
                        <GroupBox.Style>
                            <Style TargetType="GroupBox" BasedOn="{StaticResource SectionGroup}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedDisk}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </GroupBox.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Model" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedDisk.FriendlyName}" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Serial Number" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedDisk.SerialNumber}" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Firmware" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedDisk.FirmwareVersion}" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Media Type" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedDisk.MediaType}" Margin="0,3"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Bus Type" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedDisk.BusType}" Margin="0,3"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Capacity" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding DiskSizeText}" Margin="0,3"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Health" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedDisk.HealthStatus}" FontWeight="SemiBold" Margin="0,3"/>
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Sector Sizes" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SectorSizeText}" Margin="0,3"/>
                        </Grid>
                    </GroupBox>

                    <Border Margin="0,0,0,10" Padding="12,10" CornerRadius="5"
                            AutomationProperties.Name="Disk health status">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource NoticePanel}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedDisk}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HealthStatusText}" Value="Good">
                                        <Setter Property="Background" Value="{DynamicResource SuccessSoftBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HealthStatusText}" Value="Warning">
                                        <Setter Property="Background" Value="{DynamicResource WarningSoftBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HealthStatusText}" Value="Critical">
                                        <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding HealthStatusText}" FontWeight="Bold" FontSize="15"
                                           Foreground="{DynamicResource TextBrush}" Margin="0,0,12,0"/>
                                <TextBlock Text="{Binding HealthReasonText}" FontSize="13"
                                           Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center"
                                           ToolTip="{Binding HealthReasonText}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SelfTestStatus}" FontSize="12"
                                       Foreground="{DynamicResource SubtextBrush}" Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       AutomationProperties.Name="SMART self-test status"/>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,0,10" Padding="12,8" CornerRadius="5">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource NoticePanel}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMonitoring}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="Live Temperature Monitor" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding LiveTemperatureText}"
                                       Foreground="{DynamicResource SubtextBrush}" FontSize="13"
                                       AutomationProperties.Name="Live disk temperatures"/>
                        </StackPanel>
                    </Border>

                    <GroupBox Header="Temperature Alerts">
                        <GroupBox.Style>
                            <Style TargetType="GroupBox" BasedOn="{StaticResource SectionGroup}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasTemperatureAlerts}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </GroupBox.Style>
                        <ListView ItemsSource="{Binding TemperatureAlerts}"
                                  BorderThickness="0"
                                  FontSize="12.5"
                                  MaxHeight="200"
                                  AutomationProperties.Name="Temperature alert history">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Time" Width="80" DisplayMemberBinding="{Binding Timestamp, StringFormat=HH:mm:ss}"/>
                                    <GridViewColumn Header="Severity" Width="80" DisplayMemberBinding="{Binding Severity}"/>
                                    <GridViewColumn Header="Disk" Width="200" DisplayMemberBinding="{Binding DeviceName}"/>
                                    <GridViewColumn Header="Temp" Width="60" DisplayMemberBinding="{Binding Temperature, StringFormat={}{0} C}"/>
                                    <GridViewColumn Header="Details" Width="350" DisplayMemberBinding="{Binding Message}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </GroupBox>

                    <GroupBox Header="SMART / Reliability Data">
                        <GroupBox.Style>
                            <Style TargetType="GroupBox" BasedOn="{StaticResource SectionGroup}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSmartData}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedDisk}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </GroupBox.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Temperature" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TemperatureText}" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Wear Used" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding WearText}" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Power-On Time" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PowerOnText}" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Read Errors" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ReadErrorsText}" Margin="0,3"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Write Errors" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding WriteErrorsText}" Margin="0,3"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Max Read Latency" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ReadLatencyText}" Margin="0,3"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Max Write Latency" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding WriteLatencyText}" Margin="0,3"/>

                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Reallocated Sectors" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding ReallocatedSectorsText}" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="Pending Sectors" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="4" Text="{Binding PendingSectorsText}" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="Power Cycles" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="4" Text="{Binding PowerCycleText}" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="3" Text="Total Written" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="4" Text="{Binding TotalWrittenText}" Margin="0,3"/>
                            <TextBlock Grid.Row="4" Grid.Column="3" Text="Total Read" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="4" Grid.Column="4" Text="{Binding TotalReadText}" Margin="0,3"/>
                            <TextBlock Grid.Row="5" Grid.Column="3" Text="NVMe Available Spare" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="5" Grid.Column="4" Text="{Binding NvmeAvailableSpareText}" Margin="0,3"/>
                            <TextBlock Grid.Row="6" Grid.Column="3" Text="NVMe Media Errors" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="6" Grid.Column="4" Text="{Binding NvmeMediaErrorsText}" Margin="0,3"/>
                            <TextBlock Grid.Row="7" Grid.Column="3" Text="Unsafe Shutdowns" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="7" Grid.Column="4" Text="{Binding NvmeUnsafeShutdownsText}" Margin="0,3"/>
                            <TextBlock Grid.Row="8" Grid.Column="3" Text="Controller Busy Time" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="8" Grid.Column="4" Text="{Binding NvmeControllerBusyText}" Margin="0,3"/>
                            <TextBlock Grid.Row="9" Grid.Column="3" Text="Error Log Entries" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="9" Grid.Column="4" Text="{Binding NvmeErrorLogText}" Margin="0,3"/>
                            <TextBlock Grid.Row="10" Grid.Column="3" Text="Critical Warning" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="10" Grid.Column="4" Text="{Binding NvmeCriticalWarningText}" Margin="0,3"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="SSD Endurance">
                        <GroupBox.Style>
                            <Style TargetType="GroupBox" BasedOn="{StaticResource SectionGroup}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasEnduranceData}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </GroupBox.Style>
                        <StackPanel>
                            <TextBlock Text="{Binding EnduranceText}" Style="{StaticResource CaptionText}" Margin="0,0,0,6"
                                       AutomationProperties.Name="Endurance status"/>
                            <ProgressBar Value="{Binding EndurancePercent}" Maximum="100" Height="6"
                                         Foreground="{DynamicResource PrimaryBrush}"
                                         Background="{DynamicResource BorderBrush}"
                                         BorderThickness="0" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Rated TBW (TB):" Style="{StaticResource FieldLabelText}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding RatedTbwTB, UpdateSourceTrigger=LostFocus}" Width="80" Height="28"
                                         AutomationProperties.Name="Rated TBW in terabytes"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="SMART Trend Alerts">
                        <GroupBox.Style>
                            <Style TargetType="GroupBox" BasedOn="{StaticResource SectionGroup}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasTrends}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </GroupBox.Style>
                        <StackPanel>
                            <TextBlock Style="{StaticResource CaptionText}" Margin="0,0,0,8">
                                <Run Text="History:"/>
                                <Run Text="{Binding HistoryCountText, Mode=OneWay}"/>
                            </TextBlock>
                            <ListView ItemsSource="{Binding Trends}"
                                      BorderThickness="0"
                                      FontSize="12.5"
                                      AutomationProperties.Name="SMART trend alerts">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Severity" Width="80" DisplayMemberBinding="{Binding Severity}"/>
                                        <GridViewColumn Header="Attribute" Width="170" DisplayMemberBinding="{Binding Attribute}"/>
                                        <GridViewColumn Header="Direction" Width="100" DisplayMemberBinding="{Binding Direction}"/>
                                        <GridViewColumn Header="Details" Width="420" DisplayMemberBinding="{Binding Message}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="All SMART Attributes">
                        <GroupBox.Style>
                            <Style TargetType="GroupBox" BasedOn="{StaticResource SectionGroup}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasExtendedSmartData}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </GroupBox.Style>
                        <ListView ItemsSource="{Binding SmartAttributes}"
                                  BorderThickness="0"
                                  FontSize="12.5"
                                  MaxHeight="300"
                                  AutomationProperties.Name="SMART attributes table">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="ID" Width="50" DisplayMemberBinding="{Binding Id}"/>
                                    <GridViewColumn Header="Attribute" Width="250" DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="Raw Value" Width="150" DisplayMemberBinding="{Binding RawDisplay}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </GroupBox>

                    <Border Margin="0,0,0,12">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource NoticePanel}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSmartData}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedDisk}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="SMART reliability data is not available for the selected disk."
                                   Style="{StaticResource CaptionText}"/>
                    </Border>

                    <GroupBox Header="4K Alignment Audit">
                        <GroupBox.Style>
                            <Style TargetType="GroupBox" BasedOn="{StaticResource SectionGroup}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedDisk}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </GroupBox.Style>
                        <Grid>
                            <ListView ItemsSource="{Binding AlignmentEntries}"
                                      BorderThickness="0"
                                      FontSize="12.5"
                                      MinHeight="150"
                                      AutomationProperties.Name="4K alignment audit table">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Partition" Width="140" DisplayMemberBinding="{Binding PartitionDisplay}"/>
                                        <GridViewColumn Header="Letter" Width="70" DisplayMemberBinding="{Binding LetterDisplay}"/>
                                        <GridViewColumn Header="Offset" Width="150" DisplayMemberBinding="{Binding OffsetDisplay}"/>
                                        <GridViewColumn Header="Aligned" Width="86" DisplayMemberBinding="{Binding AlignedDisplay}"/>
                                        <GridViewColumn Header="Status" Width="320" DisplayMemberBinding="{Binding Status}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <Border IsHitTestVisible="False">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource EmptyStatePanel}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AlignmentEntries.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="No alignment entries" Style="{StaticResource EmptyStateTitle}"/>
                                    <TextBlock Text="Alignment details will appear after health data loads."
                                               Style="{StaticResource EmptyStateText}"
                                               Margin="0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <Border Style="{StaticResource BusyOverlay}">
            <Border Style="{StaticResource BusyPanel}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Loading health data"
                               Style="{StaticResource PageTitleText}"
                               HorizontalAlignment="Center"/>
                    <ProgressBar Style="{StaticResource BusyProgress}" IsIndeterminate="True"/>
                    <TextBlock Text="Reading physical disk, SMART, and alignment details."
                               Style="{StaticResource CaptionText}"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
