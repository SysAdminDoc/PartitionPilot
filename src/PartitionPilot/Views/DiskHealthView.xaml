<UserControl x:Class="PartitionPilot.Views.DiskHealthView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <DockPanel IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
            <Border DockPanel.Dock="Top" Style="{StaticResource PanelCard}" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Disk Health" Style="{StaticResource PageTitleText}"/>
                        <TextBlock Text="Review physical disk status, reliability telemetry, and alignment."
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Physical Disk"
                                   Style="{StaticResource FieldLabelText}"
                                   Margin="0,0,10,0"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding PhysicalDisks}"
                                  SelectedItem="{Binding SelectedDisk}"
                                  DisplayMemberPath="DisplayText"
                                  MinWidth="420"
                                  Height="34"
                                  FontSize="13"
                                  AutomationProperties.Name="Physical disk selector"/>
                        <Button Grid.Column="2"
                                Content="Refresh"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource ToolbarButton}"
                                Margin="10,0,0,0"
                                AutomationProperties.Name="Refresh disk health"/>
                    </Grid>
                </Grid>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,8,0">
                    <Border MinHeight="100">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource EmptyStatePanel}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PhysicalDisks.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="No disk health data loaded" Style="{StaticResource EmptyStateTitle}"/>
                            <TextBlock Text="Refresh to load physical disk, SMART reliability, and alignment details."
                                       Style="{StaticResource EmptyStateText}"
                                       Margin="0"/>
                        </StackPanel>
                    </Border>

                    <GroupBox Header="Disk Information">
                        <GroupBox.Style>
                            <Style TargetType="GroupBox" BasedOn="{StaticResource SectionGroup}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedDisk}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </GroupBox.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Model" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedDisk.FriendlyName}" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Serial Number" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedDisk.SerialNumber}" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Firmware" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedDisk.FirmwareVersion}" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Media Type" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedDisk.MediaType}" Margin="0,3"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Bus Type" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedDisk.BusType}" Margin="0,3"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Capacity" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding DiskSizeText}" Margin="0,3"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Health" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedDisk.HealthStatus}" FontWeight="SemiBold" Margin="0,3"/>
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Sector Sizes" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SectorSizeText}" Margin="0,3"/>
                        </Grid>
                    </GroupBox>

                    <Border Margin="0,0,0,10" Padding="12,8" CornerRadius="4"
                            AutomationProperties.Name="Disk health status">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedDisk}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.Background>
                            <SolidColorBrush Color="{Binding HealthStatusColor}"/>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding HealthStatusText}" FontWeight="Bold" FontSize="15"
                                       Foreground="#111315" Margin="0,0,12,0"/>
                            <TextBlock Text="{Binding HealthReasonText}" FontSize="13"
                                       Foreground="#1A1D21" VerticalAlignment="Center"
                                       ToolTip="{Binding HealthReasonText}"/>
                        </StackPanel>
                    </Border>

                    <GroupBox Header="SMART / Reliability Data">
                        <GroupBox.Style>
                            <Style TargetType="GroupBox" BasedOn="{StaticResource SectionGroup}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSmartData}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedDisk}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </GroupBox.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Temperature" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TemperatureText}" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Wear Used" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding WearText}" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Power-On Time" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PowerOnText}" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Read Errors" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ReadErrorsText}" Margin="0,3"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Write Errors" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding WriteErrorsText}" Margin="0,3"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Max Read Latency" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ReadLatencyText}" Margin="0,3"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Max Write Latency" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding WriteLatencyText}" Margin="0,3"/>
                        </Grid>
                    </GroupBox>

                    <Border Margin="0,0,0,12">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource NoticePanel}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSmartData}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedDisk}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="SMART reliability data is not available for the selected disk."
                                   Style="{StaticResource CaptionText}"/>
                    </Border>

                    <GroupBox Header="4K Alignment Audit">
                        <GroupBox.Style>
                            <Style TargetType="GroupBox" BasedOn="{StaticResource SectionGroup}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedDisk}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </GroupBox.Style>
                        <Grid>
                            <ListView ItemsSource="{Binding AlignmentEntries}"
                                      BorderThickness="0"
                                      FontSize="12.5"
                                      MinHeight="150"
                                      AutomationProperties.Name="4K alignment audit table">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Partition" Width="140" DisplayMemberBinding="{Binding PartitionDisplay}"/>
                                        <GridViewColumn Header="Letter" Width="70" DisplayMemberBinding="{Binding LetterDisplay}"/>
                                        <GridViewColumn Header="Offset" Width="150" DisplayMemberBinding="{Binding OffsetDisplay}"/>
                                        <GridViewColumn Header="Aligned" Width="86" DisplayMemberBinding="{Binding AlignedDisplay}"/>
                                        <GridViewColumn Header="Status" Width="320" DisplayMemberBinding="{Binding Status}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <Border IsHitTestVisible="False">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource EmptyStatePanel}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AlignmentEntries.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="No alignment entries" Style="{StaticResource EmptyStateTitle}"/>
                                    <TextBlock Text="Alignment details will appear after health data loads."
                                               Style="{StaticResource EmptyStateText}"
                                               Margin="0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <Border Style="{StaticResource BusyOverlay}">
            <Border Style="{StaticResource BusyPanel}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Loading health data"
                               Style="{StaticResource PageTitleText}"
                               HorizontalAlignment="Center"/>
                    <ProgressBar Style="{StaticResource BusyProgress}" IsIndeterminate="True"/>
                    <TextBlock Text="Reading physical disk, SMART, and alignment details."
                               Style="{StaticResource CaptionText}"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
