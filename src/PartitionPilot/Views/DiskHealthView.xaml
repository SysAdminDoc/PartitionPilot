<UserControl x:Class="PartitionPilot.Views.DiskHealthView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PartitionPilot">
    <Grid>
        <DockPanel IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
            <Border DockPanel.Dock="Top" Style="{StaticResource PanelCard}" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="{local:Loc TabDiskHealth}" Style="{StaticResource PageTitleText}"/>
                        <TextBlock Text="{local:Loc DiskHealthDescription}"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{local:Loc PhysicalDisk}"
                                   Style="{StaticResource FieldLabelText}"
                                   Margin="0,0,10,0"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding PhysicalDisks}"
                                  SelectedItem="{Binding SelectedDisk}"
                                  ItemTemplate="{StaticResource PhysicalDiskInfoComboTemplate}"
                                  MinWidth="420"
                                  Height="34"
                                  FontSize="13"
                                  AutomationProperties.Name="{local:Loc Xaml_PhysicalDiskSelector}"/>
                        <Button Grid.Column="2"
                                Content="{local:Loc Refresh}"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource ToolbarButton}"
                                Margin="10,0,0,0"
                                AutomationProperties.Name="{local:Loc Xaml_RefreshDiskHealth}"/>
                        <Button Grid.Column="3"
                                Content="{Binding MonitorButtonText}"
                                Command="{Binding ToggleMonitorCommand}"
                                Style="{StaticResource ToolbarButton}"
                                Margin="6,0,0,0"
                                AutomationProperties.Name="{local:Loc Xaml_ToggleTemperatureMonitoring}"/>
                        <Button Grid.Column="4"
                                Content="{local:Loc Xaml_ExportReport}"
                                Command="{Binding ExportReportCommand}"
                                Style="{StaticResource ToolbarButton}"
                                Margin="6,0,0,0"
                                AutomationProperties.Name="{local:Loc Xaml_ExportSMARTDiagnosticReport}"/>
                        <Button Grid.Column="5"
                                Content="{local:Loc Xaml_ShortTest}"
                                Command="{Binding RunShortTestCommand}"
                                IsEnabled="{Binding CanRunSmartSelfTest}"
                                Style="{StaticResource ToolbarButton}"
                                Margin="6,0,0,0"
                                ToolTip="{Binding SmartSelfTestSupportText}"
                                AutomationProperties.Name="{local:Loc Xaml_RunSMARTShortSelfTest}"/>
                        <Button Grid.Column="6"
                                Content="{local:Loc Xaml_ExtendedTest}"
                                Command="{Binding RunExtendedTestCommand}"
                                IsEnabled="{Binding CanRunSmartSelfTest}"
                                Style="{StaticResource ToolbarButton}"
                                Margin="6,0,0,0"
                                ToolTip="{Binding SmartSelfTestSupportText}"
                                AutomationProperties.Name="{local:Loc Xaml_RunSMARTExtendedSelfTest}"/>
                        <Button Grid.Column="7"
                                Content="{Binding PerfButtonText}"
                                Command="{Binding TogglePerfCountersCommand}"
                                Style="{StaticResource ToolbarButton}"
                                Margin="6,0,0,0"
                                AutomationProperties.Name="{local:Loc Xaml_ToggleDiskIOMonitoring}"/>
                    </Grid>
                </Grid>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,8,0">
                    <Border MinHeight="100">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource EmptyStatePanel}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PhysicalDisks.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{local:Loc Xaml_NoDiskHealthDataLoaded}" Style="{StaticResource EmptyStateTitle}"/>
                            <TextBlock Text="{local:Loc Xaml_RefreshToLoadPhysicalDiskSMARTReliabilityAndAlignmentDetails}"
                                       Style="{StaticResource EmptyStateText}"
                                       Margin="0"/>
                        </StackPanel>
                    </Border>

                    <GroupBox Header="{local:Loc DiskInformation}">
                        <GroupBox.Style>
                            <Style TargetType="GroupBox" BasedOn="{StaticResource SectionGroup}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedDisk}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </GroupBox.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{local:Loc Model}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedDisk.FriendlyName}" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{local:Loc SerialNumber}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedDisk.SerialNumber}" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{local:Loc Firmware}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedDisk.FirmwareVersion}" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{local:Loc MediaType}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedDisk.MediaType}" Margin="0,3"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{local:Loc BusType}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedDisk.BusType}" Margin="0,3"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="{local:Loc Capacity}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding DiskSizeText}" Margin="0,3"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="{local:Loc Health}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedDisk.HealthStatus}" FontWeight="SemiBold" Margin="0,3"/>
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="{local:Loc SectorSizes}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SectorSizeText}" Margin="0,3"/>
                        </Grid>
                    </GroupBox>

                    <Border Margin="0,0,0,10" Padding="12,10" CornerRadius="5"
                            AutomationProperties.Name="{local:Loc Xaml_DiskHealthStatus}">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource NoticePanel}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedDisk}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HealthStatusText}" Value="Good">
                                        <Setter Property="Background" Value="{DynamicResource SuccessSoftBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HealthStatusText}" Value="Warning">
                                        <Setter Property="Background" Value="{DynamicResource WarningSoftBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HealthStatusText}" Value="Critical">
                                        <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding HealthStatusText}" FontWeight="Bold" FontSize="15"
                                           Foreground="{DynamicResource TextBrush}" Margin="0,0,12,0"/>
                                <TextBlock Text="{Binding HealthReasonText}" FontSize="13"
                                           Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center"
                                           ToolTip="{Binding HealthReasonText}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SelfTestStatus}" FontSize="12"
                                       Foreground="{DynamicResource SubtextBrush}" Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       AutomationProperties.Name="{local:Loc Xaml_SMARTSelfTestStatus}"/>
                            <TextBlock Text="{Binding SmartSelfTestSupportText}" FontSize="12"
                                       Foreground="{DynamicResource SubtextBrush}" Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       AutomationProperties.Name="{local:Loc Xaml_SMARTSelfTestAvailability}"/>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,0,10" Padding="12,8" CornerRadius="5">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource NoticePanel}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMonitoring}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="{local:Loc Xaml_LiveTemperatureMonitor}" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding LiveTemperatureText}"
                                       Foreground="{DynamicResource SubtextBrush}" FontSize="13"
                                       AutomationProperties.Name="{local:Loc Xaml_LiveDiskTemperatures}"/>
                        </StackPanel>
                    </Border>

                    <GroupBox Header="{local:Loc TemperatureAlerts}">
                        <GroupBox.Style>
                            <Style TargetType="GroupBox" BasedOn="{StaticResource SectionGroup}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasTemperatureAlerts}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </GroupBox.Style>
                        <ListView ItemsSource="{Binding TemperatureAlerts}"
                                  BorderThickness="0"
                                  FontSize="12.5"
                                  MaxHeight="200"
                                  AutomationProperties.Name="{local:Loc Xaml_TemperatureAlertHistory}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="{local:Loc Xaml_Time}" Width="80" DisplayMemberBinding="{Binding Timestamp, StringFormat=HH:mm:ss}"/>
                                    <GridViewColumn Header="{local:Loc Xaml_Severity}" Width="80" DisplayMemberBinding="{Binding Severity}"/>
                                    <GridViewColumn Header="{local:Loc Xaml_Disk}" Width="200" DisplayMemberBinding="{Binding DeviceName}"/>
                                    <GridViewColumn Header="{local:Loc Xaml_Temp}" Width="60" DisplayMemberBinding="{Binding Temperature, StringFormat={}{0} C}"/>
                                    <GridViewColumn Header="{local:Loc Xaml_Details}" Width="350" DisplayMemberBinding="{Binding Message}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </GroupBox>

                    <GroupBox Header="{local:Loc Xaml_DiskIOActivity}">
                        <GroupBox.Style>
                            <Style TargetType="GroupBox" BasedOn="{StaticResource SectionGroup}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPerfMonitoring}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </GroupBox.Style>
                        <TextBlock Text="{Binding PerfText}" FontFamily="Consolas" FontSize="12"
                                   Foreground="{DynamicResource TextBrush}"
                                   TextWrapping="NoWrap"
                                   AutomationProperties.Name="{local:Loc Xaml_DiskIOPerformanceCounters}"/>
                    </GroupBox>

                    <GroupBox Header="{local:Loc SmartReliabilityData}">
                        <GroupBox.Style>
                            <Style TargetType="GroupBox" BasedOn="{StaticResource SectionGroup}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSmartData}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedDisk}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </GroupBox.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{local:Loc Temperature}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TemperatureText}" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{local:Loc WearUsed}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding WearText}" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{local:Loc PowerOnTime}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PowerOnText}" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{local:Loc ReadErrors}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ReadErrorsText}" Margin="0,3"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{local:Loc WriteErrors}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding WriteErrorsText}" Margin="0,3"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="{local:Loc MaxReadLatency}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ReadLatencyText}" Margin="0,3"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="{local:Loc MaxWriteLatency}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding WriteLatencyText}" Margin="0,3"/>

                            <TextBlock Grid.Row="0" Grid.Column="3" Text="{local:Loc ReallocatedSectors}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding ReallocatedSectorsText}" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="{local:Loc PendingSectors}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="4" Text="{Binding PendingSectorsText}" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="{local:Loc PowerCycles}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="4" Text="{Binding PowerCycleText}" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="3" Text="{local:Loc TotalWritten}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="4" Text="{Binding TotalWrittenText}" Margin="0,3"/>
                            <TextBlock Grid.Row="4" Grid.Column="3" Text="{local:Loc TotalRead}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="4" Grid.Column="4" Text="{Binding TotalReadText}" Margin="0,3"/>
                            <TextBlock Grid.Row="5" Grid.Column="3" Text="{local:Loc NvmeAvailableSpare}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="5" Grid.Column="4" Text="{Binding NvmeAvailableSpareText}" Margin="0,3"/>
                            <TextBlock Grid.Row="6" Grid.Column="3" Text="{local:Loc NvmeMediaErrors}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="6" Grid.Column="4" Text="{Binding NvmeMediaErrorsText}" Margin="0,3"/>
                            <TextBlock Grid.Row="7" Grid.Column="3" Text="{local:Loc Xaml_UnsafeShutdowns}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="7" Grid.Column="4" Text="{Binding NvmeUnsafeShutdownsText}" Margin="0,3"/>
                            <TextBlock Grid.Row="8" Grid.Column="3" Text="{local:Loc Xaml_ControllerBusyTime}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="8" Grid.Column="4" Text="{Binding NvmeControllerBusyText}" Margin="0,3"/>
                            <TextBlock Grid.Row="9" Grid.Column="3" Text="{local:Loc Xaml_ErrorLogEntries}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="9" Grid.Column="4" Text="{Binding NvmeErrorLogText}" Margin="0,3"/>
                            <TextBlock Grid.Row="10" Grid.Column="3" Text="{local:Loc Xaml_CriticalWarning}" Style="{StaticResource FieldLabelText}" Margin="0,3"/>
                            <TextBlock Grid.Row="10" Grid.Column="4" Text="{Binding NvmeCriticalWarningText}" Margin="0,3"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="{local:Loc Xaml_SSDEndurance}">
                        <GroupBox.Style>
                            <Style TargetType="GroupBox" BasedOn="{StaticResource SectionGroup}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasEnduranceData}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </GroupBox.Style>
                        <StackPanel>
                            <TextBlock Text="{Binding EnduranceText}" Style="{StaticResource CaptionText}" Margin="0,0,0,6"
                                       AutomationProperties.Name="{local:Loc Xaml_EnduranceStatus}"/>
                            <ProgressBar Value="{Binding EndurancePercent}" Maximum="100" Height="6"
                                         Foreground="{DynamicResource PrimaryBrush}"
                                         Background="{DynamicResource BorderBrush}"
                                         BorderThickness="0" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{local:Loc Xaml_RatedTBWTB}" Style="{StaticResource FieldLabelText}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding RatedTbwTB, UpdateSourceTrigger=LostFocus}" Width="80" Height="28"
                                         AutomationProperties.Name="{local:Loc Xaml_RatedTBWInTerabytes}"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="{local:Loc SmartTrendAlerts}">
                        <GroupBox.Style>
                            <Style TargetType="GroupBox" BasedOn="{StaticResource SectionGroup}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasTrends}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </GroupBox.Style>
                        <StackPanel>
                            <TextBlock Style="{StaticResource CaptionText}" Margin="0,0,0,8">
                                <Run Text="{local:Loc Xaml_History}"/>
                                <Run Text="{Binding HistoryCountText, Mode=OneWay}"/>
                            </TextBlock>
                            <ListView ItemsSource="{Binding Trends}"
                                      BorderThickness="0"
                                      FontSize="12.5"
                                      AutomationProperties.Name="{local:Loc SmartTrendAlerts}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{local:Loc Xaml_Severity}" Width="80" DisplayMemberBinding="{Binding Severity}"/>
                                        <GridViewColumn Header="{local:Loc Xaml_Attribute}" Width="170" DisplayMemberBinding="{Binding Attribute}"/>
                                        <GridViewColumn Header="{local:Loc Xaml_Direction}" Width="100" DisplayMemberBinding="{Binding Direction}"/>
                                        <GridViewColumn Header="{local:Loc Xaml_Details}" Width="420" DisplayMemberBinding="{Binding Message}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="{local:Loc AllSmartAttributes}">
                        <GroupBox.Style>
                            <Style TargetType="GroupBox" BasedOn="{StaticResource SectionGroup}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasExtendedSmartData}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </GroupBox.Style>
                        <ListView ItemsSource="{Binding SmartAttributes}"
                                  BorderThickness="0"
                                  FontSize="12.5"
                                  MaxHeight="300"
                                  AutomationProperties.Name="{local:Loc Xaml_SMARTAttributesTable}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="{local:Loc Xaml_ID}" Width="50" DisplayMemberBinding="{Binding Id}"/>
                                    <GridViewColumn Header="{local:Loc Xaml_Attribute}" Width="250" DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="{local:Loc Xaml_RawValue}" Width="150" DisplayMemberBinding="{Binding RawDisplay}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </GroupBox>

                    <Border Margin="0,0,0,12">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource NoticePanel}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSmartData}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedDisk}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{local:Loc Xaml_SMARTReliabilityDataIsNotAvailableForTheSelectedDisk}"
                                   Style="{StaticResource CaptionText}"/>
                    </Border>

                    <GroupBox Header="{local:Loc AlignmentAudit}">
                        <GroupBox.Style>
                            <Style TargetType="GroupBox" BasedOn="{StaticResource SectionGroup}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedDisk}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </GroupBox.Style>
                        <Grid>
                            <ListView ItemsSource="{Binding AlignmentEntries}"
                                      BorderThickness="0"
                                      FontSize="12.5"
                                      MinHeight="150"
                                      AutomationProperties.Name="{local:Loc Xaml_4KAlignmentAuditTable}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{local:Loc Xaml_Partition}" Width="140" DisplayMemberBinding="{Binding PartitionDisplay}"/>
                                        <GridViewColumn Header="{local:Loc Xaml_Letter}" Width="70" DisplayMemberBinding="{Binding LetterDisplay}"/>
                                        <GridViewColumn Header="{local:Loc Xaml_Offset}" Width="150" DisplayMemberBinding="{Binding OffsetDisplay}"/>
                                        <GridViewColumn Header="{local:Loc Xaml_Aligned}" Width="86" DisplayMemberBinding="{Binding AlignedDisplay}"/>
                                        <GridViewColumn Header="{local:Loc Xaml_Status}" Width="320" DisplayMemberBinding="{Binding Status}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <Border IsHitTestVisible="False">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource EmptyStatePanel}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AlignmentEntries.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{local:Loc Xaml_NoAlignmentEntries}" Style="{StaticResource EmptyStateTitle}"/>
                                    <TextBlock Text="{local:Loc Xaml_AlignmentDetailsWillAppearAfterHealthDataLoads}"
                                               Style="{StaticResource EmptyStateText}"
                                               Margin="0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <Border Style="{StaticResource BusyOverlay}">
            <Border Style="{StaticResource BusyPanel}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{local:Loc Xaml_LoadingHealthData}"
                               Style="{StaticResource PageTitleText}"
                               HorizontalAlignment="Center"/>
                    <ProgressBar Style="{StaticResource BusyProgress}" IsIndeterminate="True"/>
                    <TextBlock Text="{local:Loc Xaml_ReadingPhysicalDiskSMARTAndAlignmentDetails}"
                               Style="{StaticResource CaptionText}"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
