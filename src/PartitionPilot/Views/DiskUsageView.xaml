<UserControl x:Class="PartitionPilot.Views.DiskUsageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PartitionPilot"
             xmlns:ctrl="clr-namespace:PartitionPilot.Controls">
    <Grid>
        <DockPanel IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
            <Border DockPanel.Dock="Top" Style="{StaticResource PanelCard}" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{local:Loc Xaml_DiskUsageAnalysis}" Style="{StaticResource PageTitleText}"/>
                        <TextBlock Text="{local:Loc Xaml_ScanAVolumeToSeeWhichFoldersConsumeTheMostSpace}"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="{local:Loc Xaml_Drive}" Style="{StaticResource FieldLabelText}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding DriveLetters}"
                                  SelectedItem="{Binding SelectedDrive}"
                                  Width="60" Height="34"
                                  Margin="0,0,10,0"
                                  AutomationProperties.Name="{local:Loc Xaml_DriveLetterSelector}"/>
                        <Button Content="{local:Loc Scan}"
                                Command="{Binding ScanCommand}"
                                Style="{StaticResource PrimaryButton}"
                                MinWidth="80" Height="34"
                                AutomationProperties.Name="{local:Loc Xaml_ScanDiskUsage}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock DockPanel.Dock="Bottom"
                       Text="{Binding SummaryText}"
                       Style="{StaticResource CaptionText}"
                       Margin="0,6,0,0"/>

            <ctrl:TreemapControl DockPanel.Dock="Top"
                                 Items="{Binding TreemapItems}"
                                 Height="200"
                                 Margin="0,0,0,10"
                                 Visibility="{Binding HasTreemapItems, Converter={StaticResource BoolVis}}"
                                 ToolTip="{local:Loc Xaml_UseArrowKeysToInspectFoldersPressEnterOrSpaceToSelect}"
                                 AutomationProperties.Name="{local:Loc Xaml_DiskUsageTreemap}"/>

            <Border Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <ListView ItemsSource="{Binding TopFolders}"
                              BorderThickness="0"
                              Background="Transparent"
                              AutomationProperties.Name="{local:Loc Xaml_DiskUsageResults}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="{local:Loc Xaml_Folder}" Width="320"
                                                DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="{local:Loc Xaml_Size}" Width="100"
                                                DisplayMemberBinding="{Binding SizeText}"/>
                                <GridViewColumn Header="{local:Loc Xaml_Files}" Width="80"
                                                DisplayMemberBinding="{Binding FileCount}"/>
                                <GridViewColumn Header="{local:Loc Xaml_Share}" Width="160">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid Width="140" Height="16">
                                                <Border Background="{DynamicResource StatusBgBrush}"
                                                        CornerRadius="3"/>
                                                <Border Background="{DynamicResource PrimaryBrush}"
                                                        CornerRadius="3"
                                                        HorizontalAlignment="Left"
                                                        Width="{Binding Proportion, Converter={StaticResource ProportionToWidth}}"/>
                                                <TextBlock Text="{Binding Proportion, StringFormat='{}{0:P0}'}"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Border IsHitTestVisible="False">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource EmptyStatePanel}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TopFolders.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{local:Loc Xaml_NoUsageScanResults}" Style="{StaticResource EmptyStateTitle}"/>
                            <TextBlock Text="{local:Loc Xaml_ChooseADriveAndScanItToRankTheLargestTopLevelFolders}"
                                       Style="{StaticResource EmptyStateText}"
                                       Margin="0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DockPanel>

        <Border Style="{StaticResource BusyOverlay}">
            <Border Style="{StaticResource BusyPanel}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{local:Loc Xaml_ScanningDrive}"
                               Style="{StaticResource PageTitleText}"
                               HorizontalAlignment="Center"/>
                    <ProgressBar Style="{StaticResource BusyProgress}" IsIndeterminate="True"/>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="13"
                               TextAlignment="Center"/>
                    <Button Content="{local:Loc Cancel}"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource ToolbarButton}"
                            HorizontalAlignment="Center"
                            Margin="0,12,0,0"
                            AutomationProperties.Name="{local:Loc Xaml_CancelDiskUsageScan}"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
