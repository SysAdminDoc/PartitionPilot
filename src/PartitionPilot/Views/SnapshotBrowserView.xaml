<UserControl x:Class="PartitionPilot.Views.SnapshotBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <DockPanel IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
            <Border DockPanel.Dock="Top" Style="{StaticResource PanelCard}" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Partition Snapshots" Style="{StaticResource PageTitleText}"/>
                        <TextBlock Text="Review saved partition-table snapshots, export evidence, and copy guided recovery notes."
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Refresh"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource ToolbarButton}"
                                AutomationProperties.Name="Refresh partition snapshots"/>
                        <Button Content="Export JSON"
                                Command="{Binding ExportCommand}"
                                Style="{StaticResource ToolbarButton}"
                                AutomationProperties.Name="Export selected partition snapshot"/>
                        <Button Content="Copy Guidance"
                                Command="{Binding CopyRecoveryCommandsCommand}"
                                Style="{StaticResource ToolbarButton}"
                                Margin="0"
                                AutomationProperties.Name="Copy snapshot recovery guidance"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock DockPanel.Dock="Bottom"
                       Text="{Binding SummaryText}"
                       Style="{StaticResource CaptionText}"
                       Margin="0,8,0,0"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="330"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                    <Grid>
                        <ListView ItemsSource="{Binding Snapshots}"
                                  SelectedItem="{Binding SelectedSnapshot}"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  AutomationProperties.Name="Partition snapshot history">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Captured" Width="134" DisplayMemberBinding="{Binding CapturedAtText}"/>
                                    <GridViewColumn Header="Disk" Width="58" DisplayMemberBinding="{Binding DiskNumber}"/>
                                    <GridViewColumn Header="Layout" Width="104" DisplayMemberBinding="{Binding PartitionCountText}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <Border IsHitTestVisible="False">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource EmptyStatePanel}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Snapshots.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="No snapshots saved" Style="{StaticResource EmptyStateTitle}"/>
                                <TextBlock Text="Snapshots are saved before destructive partition operations and will appear here."
                                           Style="{StaticResource EmptyStateText}"
                                           Margin="0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="170"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource PanelCard}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedSnapshot.DiskSummary, TargetNullValue='No snapshot selected'}"
                                           Style="{StaticResource SectionTitleText}"/>
                                <TextBlock Text="{Binding SelectedSnapshot.FileName, TargetNullValue='Select a snapshot to inspect its saved disk layout.'}"
                                           Style="{StaticResource CaptionText}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Compare Current Layout"
                                    Command="{Binding CompareCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    AutomationProperties.Name="Compare selected snapshot with current disk layout"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="150"/>
                            </Grid.RowDefinitions>

                            <ListView Grid.Row="0"
                                      ItemsSource="{Binding SnapshotPartitions}"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      AutomationProperties.Name="Snapshot partition table">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="#" Width="44" DisplayMemberBinding="{Binding PartitionNumber}"/>
                                        <GridViewColumn Header="Letter" Width="70" DisplayMemberBinding="{Binding LetterDisplay}"/>
                                        <GridViewColumn Header="Type" Width="110" DisplayMemberBinding="{Binding Type}"/>
                                        <GridViewColumn Header="File System" Width="96" DisplayMemberBinding="{Binding FileSystem}"/>
                                        <GridViewColumn Header="Size" Width="110" DisplayMemberBinding="{Binding SizeText}"/>
                                        <GridViewColumn Header="Offset" Width="110" DisplayMemberBinding="{Binding OffsetText}"/>
                                        <GridViewColumn Header="Role" Width="170" DisplayMemberBinding="{Binding RoleText}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <TextBox Grid.Row="1"
                                     Text="{Binding DiffText}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     BorderThickness="1,1,0,0"
                                     AutomationProperties.Name="Snapshot comparison output"/>
                        </Grid>
                    </Border>

                    <TextBox Grid.Row="3"
                             Text="{Binding RecoveryCommands}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="12"
                             AutomationProperties.Name="Snapshot recovery guidance"/>
                </Grid>
            </Grid>
        </DockPanel>

        <Border Style="{StaticResource BusyOverlay}">
            <Border Style="{StaticResource BusyPanel}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Loading snapshots"
                               Style="{StaticResource PageTitleText}"
                               HorizontalAlignment="Center"/>
                    <ProgressBar Style="{StaticResource BusyProgress}" IsIndeterminate="True"/>
                    <TextBlock Text="Reading saved partition layouts and comparison data."
                               Style="{StaticResource CaptionText}"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
