<UserControl x:Class="PartitionPilot.Views.SnapshotBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PartitionPilot">
    <Grid>
        <DockPanel IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
            <Border DockPanel.Dock="Top" Style="{StaticResource PanelCard}" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{local:Loc SnapshotsTitle}" Style="{StaticResource PageTitleText}"/>
                        <TextBlock Text="{local:Loc Xaml_ReviewSavedPartitionTableSnapshotsExportEvidenceAndCopyGui_d4ae9b65}"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="{local:Loc Refresh}"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource ToolbarButton}"
                                AutomationProperties.Name="{local:Loc Xaml_RefreshPartitionSnapshots}"/>
                        <Button Content="{local:Loc Xaml_ExportJSON}"
                                Command="{Binding ExportCommand}"
                                Style="{StaticResource ToolbarButton}"
                                AutomationProperties.Name="{local:Loc Xaml_ExportSelectedPartitionSnapshot}"/>
                        <Button Content="{local:Loc RecoveryPlan}"
                                Command="{Binding ExportRecoveryPlanCommand}"
                                Style="{StaticResource ToolbarButton}"
                                ToolTip="{local:Loc Xaml_ExportAMismatchCheckedRecoveryPlanForThisSnapshot}"
                                AutomationProperties.Name="{local:Loc Xaml_ExportRecoveryPlan}"/>
                        <Button Content="{local:Loc Xaml_CopyGuidance}"
                                Command="{Binding CopyRecoveryCommandsCommand}"
                                Style="{StaticResource ToolbarButton}"
                                Margin="0"
                                AutomationProperties.Name="{local:Loc Xaml_CopySnapshotRecoveryGuidance}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock DockPanel.Dock="Bottom"
                       Text="{Binding SummaryText}"
                       Style="{StaticResource CaptionText}"
                       Margin="0,8,0,0"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="330"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                    <Grid>
                        <ListView ItemsSource="{Binding Snapshots}"
                                  SelectedItem="{Binding SelectedSnapshot}"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  AutomationProperties.Name="{local:Loc Xaml_PartitionSnapshotHistory}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="{local:Loc Xaml_Captured}" Width="134" DisplayMemberBinding="{Binding CapturedAtText}"/>
                                    <GridViewColumn Header="{local:Loc Xaml_Disk}" Width="58" DisplayMemberBinding="{Binding DiskNumber}"/>
                                    <GridViewColumn Header="{local:Loc Xaml_Layout}" Width="104" DisplayMemberBinding="{Binding PartitionCountText}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <Border IsHitTestVisible="False">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource EmptyStatePanel}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Snapshots.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{local:Loc Xaml_NoSnapshotsSaved}" Style="{StaticResource EmptyStateTitle}"/>
                                <TextBlock Text="{local:Loc Xaml_SnapshotsAreSavedBeforeDestructivePartitionOperationsAndWi_1843916b}"
                                           Style="{StaticResource EmptyStateText}"
                                           Margin="0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="170"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource PanelCard}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedSnapshot.DiskSummary, TargetNullValue='No snapshot selected'}"
                                           Style="{StaticResource SectionTitleText}"/>
                                <TextBlock Text="{Binding SelectedSnapshot.FileName, TargetNullValue='Select a snapshot to inspect its saved disk layout.'}"
                                           Style="{StaticResource CaptionText}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="{local:Loc Xaml_CompareCurrentLayout}"
                                    Command="{Binding CompareCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    AutomationProperties.Name="{local:Loc Xaml_CompareSelectedSnapshotWithCurrentDiskLayout}"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="150"/>
                            </Grid.RowDefinitions>

                            <ListView Grid.Row="0"
                                      ItemsSource="{Binding SnapshotPartitions}"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      AutomationProperties.Name="{local:Loc Xaml_SnapshotPartitionTable}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="{local:Loc XamlValue}" Width="44" DisplayMemberBinding="{Binding PartitionNumber}"/>
                                        <GridViewColumn Header="{local:Loc Xaml_Letter}" Width="70" DisplayMemberBinding="{Binding LetterDisplay}"/>
                                        <GridViewColumn Header="{local:Loc Xaml_Type}" Width="110" DisplayMemberBinding="{Binding Type}"/>
                                        <GridViewColumn Header="{local:Loc Xaml_FileSystem}" Width="96" DisplayMemberBinding="{Binding FileSystem}"/>
                                        <GridViewColumn Header="{local:Loc Xaml_Size}" Width="110" DisplayMemberBinding="{Binding SizeText}"/>
                                        <GridViewColumn Header="{local:Loc Xaml_Offset}" Width="110" DisplayMemberBinding="{Binding OffsetText}"/>
                                        <GridViewColumn Header="{local:Loc Xaml_Role}" Width="170" DisplayMemberBinding="{Binding RoleText}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <TextBox Grid.Row="1"
                                     Text="{Binding DiffText}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     BorderThickness="1,1,0,0"
                                     AutomationProperties.Name="{local:Loc Xaml_SnapshotComparisonOutput}"/>
                        </Grid>
                    </Border>

                    <TextBox Grid.Row="3"
                             Text="{Binding RecoveryCommands}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="12"
                             AutomationProperties.Name="{local:Loc Xaml_SnapshotRecoveryGuidance}"/>
                </Grid>
            </Grid>
        </DockPanel>

        <Border Style="{StaticResource BusyOverlay}">
            <Border Style="{StaticResource BusyPanel}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{local:Loc Xaml_LoadingSnapshots}"
                               Style="{StaticResource PageTitleText}"
                               HorizontalAlignment="Center"/>
                    <ProgressBar Style="{StaticResource BusyProgress}" IsIndeterminate="True"/>
                    <TextBlock Text="{local:Loc Xaml_ReadingSavedPartitionLayoutsAndComparisonData}"
                               Style="{StaticResource CaptionText}"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
