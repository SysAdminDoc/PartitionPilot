<UserControl x:Class="PartitionPilot.Views.ToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PartitionPilot">
    <Grid>
        <DockPanel IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
            <Border DockPanel.Dock="Top" Style="{StaticResource PanelCard}" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{local:Loc Xaml_MaintenanceTools}" Style="{StaticResource PageTitleText}"/>
                        <TextBlock Text="{local:Loc Xaml_RunNativeWindowsDiskUtilitiesWithClearerTargetingAndLoggedOutput}"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="{local:Loc Xaml_RefreshLists}"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource ToolbarButton}"
                            Margin="12,0,0,0"
                            AutomationProperties.Name="{local:Loc Xaml_RefreshToolLists}"/>
                </Grid>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <WrapPanel Margin="0,0,8,0">

                    <GroupBox Header="{local:Loc Xaml_ConvertMBRToGPT}" Style="{StaticResource ToolGroup}">
                        <StackPanel>
                            <TextBlock Text="{local:Loc Xaml_ValidateFirstThenConvertACompatibleSystemDiskWithoutDeleti_3693ed34}"
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="{local:Loc Xaml_Disk}" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding MbrDisks}"
                                      SelectedItem="{Binding SelectedMbrDisk}"
                                      ItemTemplate="{StaticResource DiskInfoComboTemplate}"
                                      Height="34"
                                      Margin="0,0,0,10"
                                      AutomationProperties.Name="{local:Loc Xaml_MBRDiskSelector}"/>
                            <WrapPanel>
                                <Button Content="{local:Loc Xaml_Validate}"
                                        Style="{StaticResource ToolbarButton}"
                                        Command="{Binding ValidateMbrToGptCommand}"
                                        AutomationProperties.Name="{local:Loc Xaml_ValidateMBRToGPTConversion}"/>
                                <Button Content="{local:Loc Xaml_Convert}"
                                        Style="{StaticResource PrimaryButton}"
                                        MinWidth="92"
                                        Height="34"
                                        Margin="0,0,6,6"
                                        Command="{Binding ConvertMbrToGptCommand}"
                                        AutomationProperties.Name="{local:Loc Xaml_ConvertMBRToGPT}"/>
                            </WrapPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="{local:Loc Xaml_ConvertFAT32ToNTFS}" Style="{StaticResource ToolGroup}">
                        <StackPanel>
                            <TextBlock Text="{local:Loc Xaml_OneWayConversionForFAT32VolumesThatNeedNTFSFeatures}"
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="{local:Loc Xaml_Volume}" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Fat32Volumes}"
                                      SelectedItem="{Binding SelectedFat32Volume}"
                                      Height="34"
                                      Margin="0,0,0,10"
                                      AutomationProperties.Name="{local:Loc Xaml_FAT32VolumeSelector}"/>
                            <Button Content="{local:Loc Xaml_ConvertVolume}"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ConvertFat32Command}"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="{local:Loc Xaml_ConvertFAT32ToNTFS}"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="{local:Loc Xaml_FilesystemCheckAndRepair}" Style="{StaticResource ToolGroup}">
                        <StackPanel>
                            <TextBlock Text="{local:Loc Xaml_ScanForFileSystemErrorsOrRunARepairModeOnTheSelectedVolume}"
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="{local:Loc Xaml_Volume}" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding CheckVolumes}"
                                      SelectedItem="{Binding SelectedCheckVolume}"
                                      Height="34"
                                      Margin="0,0,0,10"
                                      AutomationProperties.Name="{local:Loc Xaml_FilesystemCheckVolumeSelector}"/>
                            <WrapPanel Margin="0,0,0,10">
                                <RadioButton Content="{local:Loc Scan}" IsChecked="{Binding CheckIsScan}"/>
                                <RadioButton Content="{local:Loc Xaml_SpotFix}" IsChecked="{Binding CheckIsSpotFix}"/>
                                <RadioButton Content="{local:Loc Xaml_OfflineRepair}" IsChecked="{Binding CheckIsOffline}"/>
                            </WrapPanel>
                            <Button Content="{local:Loc Xaml_RunCheck}"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding RunFsCheckCommand}"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="{local:Loc Xaml_RunFilesystemCheck}"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="{local:Loc Xaml_OptimizeAndTRIM}" Style="{StaticResource ToolGroup}">
                        <StackPanel>
                            <TextBlock Text="{local:Loc Xaml_AnalyzeOrOptimizeHDDsAndSendRetrimToSSDBackedVolumes}"
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="{local:Loc Xaml_Volume}" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding OptVolumes}"
                                      SelectedItem="{Binding SelectedOptVolume}"
                                      Height="34"
                                      Margin="0,0,0,10"
                                      AutomationProperties.Name="{local:Loc Xaml_OptimizeVolumeSelector}"/>
                            <WrapPanel Margin="0,0,0,10">
                                <RadioButton Content="{local:Loc Xaml_Analyze}" IsChecked="{Binding OptIsAnalyze}"/>
                                <RadioButton Content="{local:Loc Xaml_Defrag}" IsChecked="{Binding OptIsDefrag}"/>
                                <RadioButton Content="{local:Loc Xaml_TRIM}" IsChecked="{Binding OptIsTrim}"/>
                            </WrapPanel>
                            <Button Content="{local:Loc Xaml_RunOptimize}"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding RunOptimizeCommand}"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="{local:Loc Xaml_RunOptimize}"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="{local:Loc SecureWipe}" Style="{StaticResource ToolGroup}">
                        <StackPanel>
                            <TextBlock Text="{local:Loc Xaml_ChooseAVolumeForFreeSpaceWipeOrADiskForFullDestructiveWipe}"
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,0,0,10"/>
                            <WrapPanel Margin="0,0,0,10">
                                <RadioButton Content="{local:Loc Xaml_FreeSpace}"
                                             GroupName="WipeMode"
                                             IsChecked="{Binding WipeIsFreeSpace}"
                                             AutomationProperties.Name="{local:Loc Xaml_WipeFreeSpaceOnly}"/>
                                <RadioButton Content="{local:Loc Xaml_EntireDisk}"
                                             GroupName="WipeMode"
                                             IsChecked="{Binding WipeIsFullDisk}"
                                             Foreground="{DynamicResource DangerBrush}"
                                             AutomationProperties.Name="{local:Loc Xaml_WipeEntireDisk}"/>
                                <RadioButton Content="{local:Loc Xaml_DoD3Pass}"
                                             GroupName="WipeMode"
                                             IsChecked="{Binding WipeIsDod3Pass}"
                                             Foreground="{DynamicResource DangerBrush}"
                                             ToolTip="{local:Loc Xaml_DoD522022M3PassOverwriteZerosOnesRandom}"
                                             AutomationProperties.Name="{local:Loc Xaml_DoD3PassWipe}"/>
                                <RadioButton Content="{local:Loc Xaml_DoD7Pass}"
                                             GroupName="WipeMode"
                                             IsChecked="{Binding WipeIsDod7Pass}"
                                             Foreground="{DynamicResource DangerBrush}"
                                             ToolTip="{local:Loc Xaml_DoD522022M7PassOverwrite}"
                                             AutomationProperties.Name="{local:Loc Xaml_DoD7PassWipe}"/>
                                <RadioButton Content="{local:Loc Xaml_NVMeFirmwareErase}"
                                             GroupName="WipeMode"
                                             IsChecked="{Binding WipeIsNvmeSanitize}"
                                             IsEnabled="{Binding IsNvmeSanitizeAvailable}"
                                             Foreground="{DynamicResource DangerBrush}"
                                             ToolTip="{Binding NvmeSanitizeAvailabilityText}"
                                             AutomationProperties.Name="{local:Loc Xaml_NVMeFirmwareErase}"/>
                            </WrapPanel>

                            <Grid Margin="0,0,0,10">
                                <StackPanel Visibility="{Binding WipeIsFreeSpace, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="{local:Loc Xaml_Volume}" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding WipeVolumes}"
                                              SelectedItem="{Binding SelectedWipeVolume}"
                                              ItemTemplate="{StaticResource VolumeInfoComboTemplate}"
                                              Height="34"
                                              AutomationProperties.Name="{local:Loc Xaml_WipeVolumeSelector}"/>
                                </StackPanel>

                                <StackPanel Visibility="{Binding WipeIsFullDisk, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="{local:Loc Xaml_Disk}" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding AllDisks}"
                                              SelectedItem="{Binding SelectedWipeDrive}"
                                              ItemTemplate="{StaticResource DiskInfoComboTemplate}"
                                              Height="34"
                                              AutomationProperties.Name="{local:Loc Xaml_WipeDiskSelector}"/>
                                </StackPanel>

                                <StackPanel Visibility="{Binding WipeIsDod3Pass, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="{local:Loc Xaml_DiskDoD3Pass}" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding AllDisks}"
                                              SelectedItem="{Binding SelectedWipeDrive}"
                                              ItemTemplate="{StaticResource DiskInfoComboTemplate}"
                                              Height="34"
                                              AutomationProperties.Name="{local:Loc Xaml_DoD3PassWipeDiskSelector}"/>
                                </StackPanel>

                                <StackPanel Visibility="{Binding WipeIsDod7Pass, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="{local:Loc Xaml_DiskDoD7Pass}" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding AllDisks}"
                                              SelectedItem="{Binding SelectedWipeDrive}"
                                              ItemTemplate="{StaticResource DiskInfoComboTemplate}"
                                              Height="34"
                                              AutomationProperties.Name="{local:Loc Xaml_DoD7PassWipeDiskSelector}"/>
                                </StackPanel>

                                <StackPanel Visibility="{Binding WipeIsNvmeSanitize, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="{local:Loc Xaml_DiskNVMeSanitize}" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding AllDisks}"
                                              SelectedItem="{Binding SelectedWipeDrive}"
                                              ItemTemplate="{StaticResource DiskInfoComboTemplate}"
                                              Height="34"
                                              AutomationProperties.Name="{local:Loc Xaml_NVMeSanitizeDiskSelector}"/>
                                    <CheckBox Content="{local:Loc Xaml_UseCryptoEraseFastestRequiresSelfEncryptingDrive}"
                                              IsChecked="{Binding UseCryptoErase}"
                                              Margin="0,6,0,0"
                                              AutomationProperties.Name="{local:Loc Xaml_UseCryptoEraseInsteadOfBlockErase}"/>
                                </StackPanel>
                            </Grid>

                            <Border Style="{StaticResource DangerNoticePanel}">
                                <TextBlock Text="{local:Loc Xaml_EntireDiskWipeIsDestructiveConfirmTheSelectedTargetBeforeStarting}"
                                           Style="{StaticResource CaptionText}"
                                           Foreground="{DynamicResource DangerBtnFgBrush}"/>
                            </Border>

                            <Button Content="{local:Loc Xaml_StartWipe}"
                                    Style="{StaticResource DangerButton}"
                                    Command="{Binding RunWipeCommand}"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="{local:Loc Xaml_StartSecureWipe}"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="{local:Loc Xaml_BootloaderRepair}" Style="{StaticResource ToolGroup}">
                        <StackPanel>
                            <TextBlock Text="{local:Loc Xaml_RebuildBootFilesForADetectedWindowsInstallation}"
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="{local:Loc Xaml_WindowsVolume}" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding WindowsInstalls}"
                                      SelectedItem="{Binding SelectedWindowsInstall}"
                                      Height="34"
                                      Margin="0,0,0,10"
                                      AutomationProperties.Name="{local:Loc Xaml_WindowsVolumeSelector}"/>
                            <Button Content="{local:Loc Xaml_RepairBootloader}"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding RunBootRepairCommand}"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="{local:Loc Xaml_RepairBootloader}"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="{local:Loc SurfaceTest}" Style="{StaticResource ToolGroup}">
                        <StackPanel>
                            <TextBlock Text="{local:Loc Xaml_ScanAVolumeForBadSectorsUsingRepairVolumeOfflineScanAndFix_b4beca22}"
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="{local:Loc Xaml_Volume}" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding SurfaceTestVolumes}"
                                      SelectedItem="{Binding SelectedSurfaceTestVolume}"
                                      Height="34"
                                      Margin="0,0,0,10"
                                      AutomationProperties.Name="{local:Loc Xaml_SurfaceTestVolumeSelector}"/>
                            <Button Content="{local:Loc Xaml_RunSurfaceTest}"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding RunSurfaceTestCommand}"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,10"
                                    AutomationProperties.Name="{local:Loc Xaml_RunSurfaceTest}"/>
                            <TextBox Text="{Binding SurfaceTestResults, Mode=OneWay}"
                                     IsReadOnly="True"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Height="80"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     AutomationProperties.Name="{local:Loc Xaml_SurfaceTestResults}"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="{local:Loc Xaml_DevDriveReFS}" Style="{StaticResource ToolGroup}"
                              IsEnabled="{Binding IsDevDriveSupported}"
                              ToolTip="{local:Loc Xaml_RequiresWindows1123H2OrNewerWithDevDriveSupport}"
                              ToolTipService.ShowOnDisabled="True">
                        <StackPanel>
                            <TextBlock Style="{StaticResource CaptionText}" Margin="0,0,0,10"
                                       Text="{local:Loc Xaml_CreateADevDriveVolumeReFSWithOptimizedIOAndAntivirusFilter_d75777a5}"/>
                            <TextBlock Text="{local:Loc Xaml_Volume}" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding DriveLetters}"
                                      SelectedItem="{Binding SelectedDevDriveLetter}"
                                      Height="34"
                                      Margin="0,0,0,10"
                                      AutomationProperties.Name="{local:Loc Xaml_DevDriveVolumeSelector}"/>
                            <Button Content="{local:Loc Xaml_CreateDevDrive}"
                                    Style="{StaticResource DangerButton}"
                                    Command="{Binding CreateDevDriveCommand}"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="{local:Loc Xaml_CreateDevDrive}"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="{local:Loc Xaml_DiskBenchmark}" Style="{StaticResource ToolGroup}">
                        <StackPanel>
                            <TextBlock Text="{local:Loc Xaml_RunDiskSpdSequentialAndRandomProfilesAgainstATemporaryTest_8ed7a19c}"
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="{local:Loc Xaml_Drive}" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding BenchDrives}"
                                      SelectedItem="{Binding SelectedBenchDrive}"
                                      Height="34"
                                      Margin="0,0,0,10"
                                      AutomationProperties.Name="{local:Loc Xaml_BenchmarkDriveSelector}"/>
                            <Button Content="{local:Loc Xaml_RunBenchmark}"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding RunBenchmarkCommand}"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,10"
                                    AutomationProperties.Name="{local:Loc Xaml_RunBenchmark}"/>
                            <TextBox Text="{Binding BenchmarkResults, Mode=OneWay}"
                                     IsReadOnly="True"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Height="116"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     AutomationProperties.Name="{local:Loc Xaml_BenchmarkResults}"/>
                            <Button Content="{local:Loc Xaml_ExportResults}"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding ExportBenchmarkCommand}"
                                    HorizontalAlignment="Left"
                                    Margin="0,6,0,0"
                                    AutomationProperties.Name="{local:Loc Xaml_ExportBenchmarkResults}"/>
                        </StackPanel>
                    </GroupBox>
                </WrapPanel>
            </ScrollViewer>
        </DockPanel>

        <Border Style="{StaticResource BusyOverlay}">
            <Border Style="{StaticResource BusyPanel}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{local:Loc Xaml_RunningTool}"
                               Style="{StaticResource PageTitleText}"
                               HorizontalAlignment="Center"/>
                    <ProgressBar Style="{StaticResource BusyProgress}" IsIndeterminate="True"/>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="13"
                               TextAlignment="Center"/>
                    <TextBlock Text="{local:Loc Xaml_OutputIsBeingCapturedInTheActivityLog}"
                               Style="{StaticResource CaptionText}"
                               Margin="0,6,0,0"
                               TextAlignment="Center"/>
                    <Button Content="{local:Loc Cancel}"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource ToolbarButton}"
                            HorizontalAlignment="Center"
                            Margin="0,12,0,0"
                            AutomationProperties.Name="{local:Loc Xaml_CancelToolOperation}"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
