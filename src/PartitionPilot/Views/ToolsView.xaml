<UserControl x:Class="PartitionPilot.Views.ToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <DockPanel IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
            <Border DockPanel.Dock="Top" Style="{StaticResource PanelCard}" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Maintenance Tools" Style="{StaticResource PageTitleText}"/>
                        <TextBlock Text="Run native Windows disk utilities with clearer targeting and logged output."
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="Refresh Lists"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource ToolbarButton}"
                            Margin="12,0,0,0"
                            AutomationProperties.Name="Refresh tool lists"/>
                </Grid>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <WrapPanel Margin="0,0,8,0">

                    <GroupBox Header="Convert MBR to GPT" Style="{StaticResource ToolGroup}">
                        <StackPanel>
                            <TextBlock Text="Validate first, then convert a compatible system disk without deleting partitions."
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Disk" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding MbrDisks}"
                                      SelectedItem="{Binding SelectedMbrDisk}"
                                      DisplayMemberPath="DisplayText"
                                      Height="34"
                                      Margin="0,0,0,10"
                                      AutomationProperties.Name="MBR disk selector"/>
                            <WrapPanel>
                                <Button Content="Validate"
                                        Style="{StaticResource ToolbarButton}"
                                        Command="{Binding ValidateMbrToGptCommand}"
                                        AutomationProperties.Name="Validate MBR to GPT conversion"/>
                                <Button Content="Convert"
                                        Style="{StaticResource PrimaryButton}"
                                        MinWidth="92"
                                        Height="34"
                                        Margin="0,0,6,6"
                                        Command="{Binding ConvertMbrToGptCommand}"
                                        AutomationProperties.Name="Convert MBR to GPT"/>
                            </WrapPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Convert FAT32 to NTFS" Style="{StaticResource ToolGroup}">
                        <StackPanel>
                            <TextBlock Text="One-way conversion for FAT32 volumes that need NTFS features."
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Volume" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Fat32Volumes}"
                                      SelectedItem="{Binding SelectedFat32Volume}"
                                      Height="34"
                                      Margin="0,0,0,10"
                                      AutomationProperties.Name="FAT32 volume selector"/>
                            <Button Content="Convert Volume"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ConvertFat32Command}"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="Convert FAT32 to NTFS"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Filesystem Check and Repair" Style="{StaticResource ToolGroup}">
                        <StackPanel>
                            <TextBlock Text="Scan for file-system errors or run a repair mode on the selected volume."
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Volume" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding CheckVolumes}"
                                      SelectedItem="{Binding SelectedCheckVolume}"
                                      Height="34"
                                      Margin="0,0,0,10"
                                      AutomationProperties.Name="Filesystem check volume selector"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <RadioButton Content="Scan" IsChecked="{Binding CheckIsScan}"/>
                                <RadioButton Content="SpotFix" IsChecked="{Binding CheckIsSpotFix}"/>
                                <RadioButton Content="Offline repair" IsChecked="{Binding CheckIsOffline}"/>
                            </StackPanel>
                            <Button Content="Run Check"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding RunFsCheckCommand}"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="Run filesystem check"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Optimize and TRIM" Style="{StaticResource ToolGroup}">
                        <StackPanel>
                            <TextBlock Text="Analyze or optimize HDDs, and send retrim to SSD-backed volumes."
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Volume" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding OptVolumes}"
                                      SelectedItem="{Binding SelectedOptVolume}"
                                      Height="34"
                                      Margin="0,0,0,10"
                                      AutomationProperties.Name="Optimize volume selector"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <RadioButton Content="Analyze" IsChecked="{Binding OptIsAnalyze}"/>
                                <RadioButton Content="Defrag" IsChecked="{Binding OptIsDefrag}"/>
                                <RadioButton Content="TRIM" IsChecked="{Binding OptIsTrim}"/>
                            </StackPanel>
                            <Button Content="Run Optimize"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding RunOptimizeCommand}"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="Run optimize"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Secure Wipe" Style="{StaticResource ToolGroup}">
                        <StackPanel>
                            <TextBlock Text="Choose a volume for free-space wipe or a disk for full destructive wipe."
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <RadioButton Content="Free space"
                                             GroupName="WipeMode"
                                             IsChecked="{Binding WipeIsFreeSpace}"
                                             AutomationProperties.Name="Wipe free space only"/>
                                <RadioButton Content="Entire disk"
                                             GroupName="WipeMode"
                                             IsChecked="{Binding WipeIsFullDisk}"
                                             Foreground="{DynamicResource DangerBrush}"
                                             AutomationProperties.Name="Wipe entire disk"/>
                                <RadioButton Content="DoD 3-pass"
                                             GroupName="WipeMode"
                                             IsChecked="{Binding WipeIsDod3Pass}"
                                             Foreground="{DynamicResource DangerBrush}"
                                             ToolTip="DoD 5220.22-M 3-pass overwrite (zeros, ones, random)"
                                             AutomationProperties.Name="DoD 3-pass wipe"/>
                                <RadioButton Content="DoD 7-pass"
                                             GroupName="WipeMode"
                                             IsChecked="{Binding WipeIsDod7Pass}"
                                             Foreground="{DynamicResource DangerBrush}"
                                             ToolTip="DoD 5220.22-M 7-pass overwrite"
                                             AutomationProperties.Name="DoD 7-pass wipe"/>
                                <RadioButton Content="NVMe firmware erase"
                                             GroupName="WipeMode"
                                             IsChecked="{Binding WipeIsNvmeSanitize}"
                                             IsEnabled="{Binding IsNvmeSanitizeAvailable}"
                                             Foreground="{DynamicResource DangerBrush}"
                                             ToolTip="{Binding NvmeSanitizeAvailabilityText}"
                                             AutomationProperties.Name="NVMe firmware erase"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,10">
                                <StackPanel Visibility="{Binding WipeIsFreeSpace, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="Volume" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding WipeVolumes}"
                                              SelectedItem="{Binding SelectedWipeVolume}"
                                              DisplayMemberPath="DisplayText"
                                              Height="34"
                                              AutomationProperties.Name="Wipe volume selector"/>
                                </StackPanel>

                                <StackPanel Visibility="{Binding WipeIsFullDisk, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="Disk" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding AllDisks}"
                                              SelectedItem="{Binding SelectedWipeDrive}"
                                              DisplayMemberPath="DisplayText"
                                              Height="34"
                                              AutomationProperties.Name="Wipe disk selector"/>
                                </StackPanel>

                                <StackPanel Visibility="{Binding WipeIsDod3Pass, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="Disk (DoD 3-pass)" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding AllDisks}"
                                              SelectedItem="{Binding SelectedWipeDrive}"
                                              DisplayMemberPath="DisplayText"
                                              Height="34"
                                              AutomationProperties.Name="DoD 3-pass wipe disk selector"/>
                                </StackPanel>

                                <StackPanel Visibility="{Binding WipeIsDod7Pass, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="Disk (DoD 7-pass)" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding AllDisks}"
                                              SelectedItem="{Binding SelectedWipeDrive}"
                                              DisplayMemberPath="DisplayText"
                                              Height="34"
                                              AutomationProperties.Name="DoD 7-pass wipe disk selector"/>
                                </StackPanel>

                                <StackPanel Visibility="{Binding WipeIsNvmeSanitize, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="Disk (NVMe Sanitize)" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding AllDisks}"
                                              SelectedItem="{Binding SelectedWipeDrive}"
                                              DisplayMemberPath="DisplayText"
                                              Height="34"
                                              AutomationProperties.Name="NVMe sanitize disk selector"/>
                                    <CheckBox Content="Use Crypto Erase (fastest, requires self-encrypting drive)"
                                              IsChecked="{Binding UseCryptoErase}"
                                              Margin="0,6,0,0"
                                              AutomationProperties.Name="Use crypto erase instead of block erase"/>
                                </StackPanel>
                            </Grid>

                            <Border Style="{StaticResource DangerNoticePanel}">
                                <TextBlock Text="Entire disk wipe is destructive. Confirm the selected target before starting."
                                           Style="{StaticResource CaptionText}"
                                           Foreground="{DynamicResource DangerBtnFgBrush}"/>
                            </Border>

                            <Button Content="Start Wipe"
                                    Style="{StaticResource DangerButton}"
                                    Command="{Binding RunWipeCommand}"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="Start secure wipe"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Bootloader Repair" Style="{StaticResource ToolGroup}">
                        <StackPanel>
                            <TextBlock Text="Rebuild boot files for a detected Windows installation."
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Windows Volume" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding WindowsInstalls}"
                                      SelectedItem="{Binding SelectedWindowsInstall}"
                                      Height="34"
                                      Margin="0,0,0,10"
                                      AutomationProperties.Name="Windows volume selector"/>
                            <Button Content="Repair Bootloader"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding RunBootRepairCommand}"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="Repair bootloader"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Surface Test" Style="{StaticResource ToolGroup}">
                        <StackPanel>
                            <TextBlock Text="Scan a volume for bad sectors using Repair-Volume OfflineScanAndFix. May take several minutes."
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Volume" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding SurfaceTestVolumes}"
                                      SelectedItem="{Binding SelectedSurfaceTestVolume}"
                                      Height="34"
                                      Margin="0,0,0,10"
                                      AutomationProperties.Name="Surface test volume selector"/>
                            <Button Content="Run Surface Test"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding RunSurfaceTestCommand}"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,10"
                                    AutomationProperties.Name="Run surface test"/>
                            <TextBox Text="{Binding SurfaceTestResults, Mode=OneWay}"
                                     IsReadOnly="True"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Height="80"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     AutomationProperties.Name="Surface test results"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Dev Drive (ReFS)" Style="{StaticResource ToolGroup}"
                              IsEnabled="{Binding IsDevDriveSupported}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource CaptionText}" Margin="0,0,0,10"
                                       Text="Create a Dev Drive volume (ReFS) with optimized I/O and antivirus filter control. Requires Windows 11 23H2+."/>
                            <TextBlock Text="Volume" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding DriveLetters}"
                                      SelectedItem="{Binding SelectedDevDriveLetter}"
                                      Height="34"
                                      Margin="0,0,0,10"
                                      AutomationProperties.Name="Dev Drive volume selector"/>
                            <Button Content="Create Dev Drive"
                                    Style="{StaticResource DangerButton}"
                                    Command="{Binding CreateDevDriveCommand}"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="Create Dev Drive"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Disk Benchmark" Style="{StaticResource ToolGroup}">
                        <StackPanel>
                            <TextBlock Text="Measure sequential and random 4K throughput using a 256 MB temporary file."
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Drive" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding BenchDrives}"
                                      SelectedItem="{Binding SelectedBenchDrive}"
                                      Height="34"
                                      Margin="0,0,0,10"
                                      AutomationProperties.Name="Benchmark drive selector"/>
                            <Button Content="Run Benchmark"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding RunBenchmarkCommand}"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,10"
                                    AutomationProperties.Name="Run benchmark"/>
                            <TextBox Text="{Binding BenchmarkResults, Mode=OneWay}"
                                     IsReadOnly="True"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Height="116"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     AutomationProperties.Name="Benchmark results"/>
                            <Button Content="Export Results"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding ExportBenchmarkCommand}"
                                    HorizontalAlignment="Left"
                                    Margin="0,6,0,0"
                                    AutomationProperties.Name="Export benchmark results"/>
                        </StackPanel>
                    </GroupBox>
                </WrapPanel>
            </ScrollViewer>
        </DockPanel>

        <Border Style="{StaticResource BusyOverlay}">
            <Border Style="{StaticResource BusyPanel}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Running tool"
                               Style="{StaticResource PageTitleText}"
                               HorizontalAlignment="Center"/>
                    <ProgressBar Style="{StaticResource BusyProgress}" IsIndeterminate="True"/>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="13"
                               TextAlignment="Center"/>
                    <TextBlock Text="Output is being captured in the activity log."
                               Style="{StaticResource CaptionText}"
                               Margin="0,6,0,0"
                               TextAlignment="Center"/>
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource ToolbarButton}"
                            HorizontalAlignment="Center"
                            Margin="0,12,0,0"
                            AutomationProperties.Name="Cancel tool operation"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
