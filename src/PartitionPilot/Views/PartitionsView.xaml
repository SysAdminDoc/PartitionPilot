<UserControl x:Class="PartitionPilot.Views.PartitionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PartitionPilot"
             xmlns:controls="clr-namespace:PartitionPilot.Controls">
    <Grid>
        <Grid IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="236"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="120"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource PanelCard}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{local:Loc Xaml_PartitionWorkspace}" Style="{StaticResource PageTitleText}"/>
                                <TextBlock Text="{local:Loc Xaml_ReviewADiskLayoutBeforeCreatingResizingFormattingOrAssigningVolumes}"
                                           Style="{StaticResource CaptionText}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="{local:Loc Refresh}"
                                    Command="{Binding RefreshCommand}"
                                    Style="{StaticResource CommandBarButton}"
                                    Margin="10,0,0,0"
                                    AutomationProperties.Name="{local:Loc Xaml_RefreshDisks}"/>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{local:Loc SelectDisk}"
                                       Style="{StaticResource FieldLabelText}"
                                       Margin="0,0,10,0"/>

                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Disks}"
                                      SelectedItem="{Binding SelectedDisk}"
                                      ItemTemplate="{StaticResource DiskInfoComboTemplate}"
                                      MinWidth="420"
                                      Height="34"
                                      FontSize="13"
                                      AutomationProperties.Name="{local:Loc Xaml_DiskSelector}"/>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{local:Loc Capacity}" Style="{StaticResource TinyLabelText}"/>
                                <TextBlock Text="{Binding DiskCapacityText}"
                                           Style="{StaticResource CaptionText}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                <TextBlock Text="{local:Loc Xaml_LargestFreeExtent}" Style="{StaticResource TinyLabelText}"/>
                                <TextBlock Text="{Binding DiskFreeExtentText}"
                                           Style="{StaticResource CaptionText}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="14,0,0,0">
                                <TextBlock Text="{local:Loc Xaml_PartitionStyle}" Style="{StaticResource TinyLabelText}"/>
                                <TextBlock Text="{Binding DiskPartitionStyleText}"
                                           Style="{StaticResource CaptionText}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <controls:DiskBarControl Grid.Row="1"
                                         Margin="0,0,0,10"
                                         Segments="{Binding DiskBarSegments}"/>

                <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                    <Grid>
                        <ListView ItemsSource="{Binding Partitions}"
                                  SelectedItem="{Binding SelectedPartition}"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  FontSize="13"
                                  AutomationProperties.Name="{local:Loc Xaml_PartitionTable}">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                                    <EventSetter Event="PreviewMouseRightButtonDown" Handler="OnPartitionRowRightClick"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{local:Loc Xaml_CreatePartition}" Click="OnCreate"/>
                                    <Separator/>
                                    <MenuItem Header="{local:Loc Xaml_DeletePartition}"
                                              Command="{Binding PlacementTarget.DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="{local:Loc Xaml_FormatPartition}" Click="OnFormat"/>
                                    <MenuItem Header="{local:Loc Xaml_ResizePartition}" Click="OnResize"/>
                                    <MenuItem Header="{local:Loc Xaml_ExtendPartition}"
                                              Command="{Binding PlacementTarget.DataContext.ExtendCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="{local:Loc Xaml_SplitPartition}" Click="OnSplit"/>
                                    <MenuItem Header="{local:Loc Xaml_ChangeDriveLetter}" Click="OnChangeLetter"/>
                                    <Separator/>
                                    <MenuItem Header="{local:Loc SetActive}"
                                              Command="{Binding PlacementTarget.DataContext.SetActiveCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="{local:Loc Xaml_HideOrUnhide}"
                                              Command="{Binding PlacementTarget.DataContext.HideCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                </ContextMenu>
                            </ListView.ContextMenu>
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="{local:Loc Xaml_Partition}" Width="180" DisplayMemberBinding="{Binding PartitionDisplay}"/>
                                    <GridViewColumn Header="{local:Loc Xaml_Type}" Width="104" DisplayMemberBinding="{Binding Type}"/>
                                    <GridViewColumn Header="{local:Loc Xaml_FileSystem}" Width="112" DisplayMemberBinding="{Binding FileSystemDisplay}"/>
                                    <GridViewColumn Header="{local:Loc Capacity}" Width="108" DisplayMemberBinding="{Binding SizeText}"/>
                                    <GridViewColumn Header="{local:Loc Xaml_Free}" Width="108" DisplayMemberBinding="{Binding FreeText}"/>
                                    <GridViewColumn Header="{local:Loc Xaml_Status}" Width="260" DisplayMemberBinding="{Binding Details}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <Border IsHitTestVisible="False">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource EmptyStatePanel}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Partitions.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{local:Loc Xaml_NoPartitionDataLoaded}" Style="{StaticResource EmptyStateTitle}"/>
                                <TextBlock Text="{local:Loc Xaml_TheWorkspaceWillPopulateAfterDiskDiscoveryCompletesOrAfter_6ed26184}"
                                           Style="{StaticResource EmptyStateText}"
                                           Margin="0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="1"
                    Style="{StaticResource PanelCard}"
                    Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <TextBlock Text="{local:Loc Xaml_PartitionActions}" Style="{StaticResource SectionTitleText}"/>
                        <TextBlock Text="{local:Loc Xaml_ActionsAreEnabledOnlyWhenTheRequiredDiskOrPartitionIsSelected}"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,2,0,12"/>

                        <Button Content="{local:Loc InitializeDisk}"
                                Style="{StaticResource ActionRailPrimaryButton}"
                                Command="{Binding InitializeDiskCommand}"
                                Visibility="{Binding IsSelectedDiskRaw, Converter={StaticResource BoolVis}}"
                                ToolTip="{local:Loc Xaml_InitializeThisUnpartitionedDiskWithAGPTPartitionTable}"
                                AutomationProperties.Name="{local:Loc InitializeDisk}"/>
                        <Button Content="{local:Loc Xaml_CreatePartition}"
                                Style="{StaticResource ActionRailPrimaryButton}"
                                Click="OnCreate"
                                IsEnabled="{Binding HasSelectedDisk}"
                                ToolTip="{local:Loc Xaml_CreateAPartitionFromUnallocatedSpace}"
                                AutomationProperties.Name="{local:Loc Xaml_CreatePartition}"/>
                        <Button Content="{local:Loc Resize}"
                                Style="{StaticResource ActionRailButton}"
                                Click="OnResize"
                                IsEnabled="{Binding HasSelectedPartition}"
                                ToolTip="{local:Loc Xaml_ResizeTheSelectedVolume}"
                                AutomationProperties.Name="{local:Loc Xaml_ResizePartition}"/>
                        <Button Content="{local:Loc Extend}"
                                Style="{StaticResource ActionRailButton}"
                                Command="{Binding ExtendCommand}"
                                ToolTip="{local:Loc Xaml_ExtendTheSelectedPartitionIntoAvailableSpace}"
                                AutomationProperties.Name="{local:Loc Xaml_ExtendPartition}"/>
                        <Button Content="{local:Loc Split}"
                                Style="{StaticResource ActionRailButton}"
                                Click="OnSplit"
                                IsEnabled="{Binding HasSelectedPartition}"
                                ToolTip="{local:Loc Xaml_SplitTheSelectedVolumeIntoTwoVolumes}"
                                AutomationProperties.Name="{local:Loc Xaml_SplitPartition}"/>
                        <Button Content="{local:Loc Merge}"
                                Style="{StaticResource ActionRailButton}"
                                Click="OnMerge"
                                IsEnabled="{Binding HasSelectedDisk}"
                                ToolTip="{local:Loc Xaml_MergeTwoAdjacentPartitionsIntoOne}"
                                AutomationProperties.Name="{local:Loc Xaml_MergePartitions}"/>
                        <Button Content="{local:Loc Format}"
                                Style="{StaticResource ActionRailButton}"
                                Click="OnFormat"
                                IsEnabled="{Binding HasSelectedPartition}"
                                ToolTip="{local:Loc Xaml_FormatTheSelectedVolume}"
                                AutomationProperties.Name="{local:Loc Xaml_FormatPartition}"/>
                        <Button Content="{local:Loc Xaml_ChangeDriveLetter}"
                                Style="{StaticResource ActionRailButton}"
                                Click="OnChangeLetter"
                                IsEnabled="{Binding HasSelectedPartition}"
                                ToolTip="{local:Loc Xaml_AssignOrChangeTheSelectedPartitionDriveLetter}"
                                AutomationProperties.Name="{local:Loc Xaml_ChangeDriveLetter}"/>
                        <Button Content="{local:Loc Xaml_HideOrUnhide}"
                                Style="{StaticResource ActionRailButton}"
                                Command="{Binding HideCommand}"
                                ToolTip="{local:Loc Xaml_HideOrUnhideTheSelectedPartition}"
                                AutomationProperties.Name="{local:Loc Xaml_HideOrUnhidePartition}"/>
                        <Button Content="{local:Loc SetActive}"
                                Style="{StaticResource ActionRailButton}"
                                Command="{Binding SetActiveCommand}"
                                ToolTip="{local:Loc Xaml_MarkTheSelectedPartitionAsActive}"
                                AutomationProperties.Name="{local:Loc Xaml_SetPartitionActive}"/>
                        <Button Content="{local:Loc Delete}"
                                Style="{StaticResource ActionRailDangerButton}"
                                Command="{Binding DeleteCommand}"
                                ToolTip="{local:Loc Xaml_DeleteTheSelectedPartition}"
                                AutomationProperties.Name="{local:Loc Xaml_DeletePartition}"/>

                        <Border Height="1"
                                Background="{DynamicResource TableRuleBrush}"
                                Margin="0,10,0,12"/>

                        <TextBlock Text="{Binding PendingCountText}"
                                   Style="{StaticResource SectionTitleText}"
                                   Margin="0,0,0,6"/>
                        <ItemsControl ItemsSource="{Binding Queue.Pending}" Margin="0,0,0,6">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource TableRuleBrush}"
                                            BorderThickness="1" CornerRadius="5"
                                            Padding="8" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Description}"
                                                           TextTrimming="CharacterEllipsis"
                                                           FontSize="11.5"
                                                           FontWeight="SemiBold"
                                                           ToolTip="{Binding Description}"
                                                           AutomationProperties.Name="{Binding Description}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding TypeDisplay}"
                                                               Style="{StaticResource TinyLabelText}"
                                                               Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding DiskTarget}"
                                                               Style="{StaticResource TinyLabelText}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="{local:Loc Remove}"
                                                    Command="{Binding DataContext.RemoveQueuedOperationCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource InlineButton}"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Top"
                                                    AutomationProperties.Name="{local:Loc Xaml_RemovePendingOperation}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                                    Visibility="{Binding HasPendingOperations, Converter={StaticResource BoolVis}}">
                            <Button Content="{local:Loc Xaml_ApplyAll}"
                                    Command="{Binding ApplyQueueCommand}"
                                    Style="{StaticResource ActionRailPrimaryButton}"
                                    Width="100" Margin="0,0,6,0"
                                    AutomationProperties.Name="{local:Loc Xaml_ApplyAllPendingOperations}"/>
                            <Button Content="{local:Loc ClearAll}"
                                    Command="{Binding ClearQueueCommand}"
                                    Style="{StaticResource ActionRailButton}"
                                    Width="78"
                                    AutomationProperties.Name="{local:Loc Xaml_ClearPendingOperations}"/>
                        </StackPanel>

                        <Border Height="1"
                                Background="{DynamicResource TableRuleBrush}"
                                Margin="0,4,0,12"/>

                        <TextBlock Text="{local:Loc Xaml_Selection}" Style="{StaticResource SectionTitleText}"/>
                        <TextBlock Text="{Binding SelectedPartitionName}"
                                   Style="{StaticResource CaptionText}"
                                   FontWeight="SemiBold"
                                   Margin="0,5,0,2"/>
                        <TextBlock Text="{Binding SelectedPartitionSummary}"
                                   Style="{StaticResource CaptionText}"/>

                        <Border Height="1"
                                Background="{DynamicResource TableRuleBrush}"
                                Margin="0,12,0,12"/>

                        <TextBlock Text="{local:Loc Xaml_Safety}" Style="{StaticResource SectionTitleText}"/>
                        <TextBlock Text="{local:Loc Xaml_DestructiveOperationsRequireConfirmationLogTheirCommandOut_3d2db885}"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Style="{StaticResource BusyOverlay}">
            <Border Style="{StaticResource BusyPanel}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{local:Loc Xaml_Working}"
                               Style="{StaticResource PageTitleText}"
                               HorizontalAlignment="Center"/>
                    <ProgressBar Style="{StaticResource BusyProgress}" IsIndeterminate="True"/>
                    <TextBlock Text="{local:Loc Xaml_QueryingDisksOrApplyingTheRequestedPartitionOperation}"
                               Style="{StaticResource CaptionText}"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
