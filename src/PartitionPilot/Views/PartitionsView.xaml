<UserControl x:Class="PartitionPilot.Views.PartitionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PartitionPilot.Controls">
    <Grid>
        <DockPanel IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
            <Border DockPanel.Dock="Top" Style="{StaticResource PanelCard}" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Disk"
                               Style="{StaticResource FieldLabelText}"
                               Margin="0,0,10,0"/>

                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Disks}"
                              SelectedItem="{Binding SelectedDisk}"
                              DisplayMemberPath="DisplayText"
                              MinWidth="420"
                              Height="34"
                              FontSize="13"
                              AutomationProperties.Name="Disk selector"/>

                    <Button Grid.Column="2"
                            Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource ToolbarButton}"
                            Margin="10,0,0,0"
                            AutomationProperties.Name="Refresh disks"/>
                </Grid>
            </Border>

            <controls:DiskBarControl DockPanel.Dock="Top"
                                     Height="76"
                                     Margin="0,0,0,10"
                                     Segments="{Binding DiskBarSegments}"/>

            <Border DockPanel.Dock="Top"
                    Style="{StaticResource PanelCard}"
                    Padding="12"
                    Margin="0,0,0,10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Partition Actions"
                               Style="{StaticResource FieldLabelText}"
                               Margin="0,0,0,8"/>
                    <WrapPanel>
                        <Button Content="Create"
                                Style="{StaticResource ToolbarButton}"
                                Click="OnCreate"
                                IsEnabled="{Binding HasSelectedDisk}"
                                ToolTip="Create a partition from unallocated space"/>
                        <Button Content="Delete"
                                Style="{StaticResource DangerButton}"
                                MinWidth="92"
                                Height="34"
                                Margin="0,0,6,6"
                                Command="{Binding DeleteCommand}"
                                ToolTip="Delete the selected partition"/>
                        <Button Content="Format"
                                Style="{StaticResource ToolbarButton}"
                                Click="OnFormat"
                                IsEnabled="{Binding HasSelectedPartition}"
                                ToolTip="Format the selected volume"/>
                        <Button Content="Resize"
                                Style="{StaticResource ToolbarButton}"
                                Click="OnResize"
                                IsEnabled="{Binding HasSelectedPartition}"
                                ToolTip="Resize the selected volume"/>
                        <Button Content="Extend"
                                Style="{StaticResource ToolbarButton}"
                                Command="{Binding ExtendCommand}"
                                ToolTip="Extend the selected partition into available space"/>
                        <Button Content="Split"
                                Style="{StaticResource ToolbarButton}"
                                Click="OnSplit"
                                IsEnabled="{Binding HasSelectedPartition}"
                                ToolTip="Split the selected volume into two volumes"/>
                        <Button Content="Change Letter"
                                Style="{StaticResource ToolbarButton}"
                                Click="OnChangeLetter"
                                IsEnabled="{Binding HasSelectedPartition}"
                                ToolTip="Assign or change the selected partition drive letter"/>
                        <Button Content="Set Active"
                                Style="{StaticResource ToolbarButton}"
                                Command="{Binding SetActiveCommand}"
                                ToolTip="Mark the selected partition as active"/>
                        <Button Content="Hide"
                                Style="{StaticResource ToolbarButton}"
                                Command="{Binding HideCommand}"
                                ToolTip="Hide or unhide the selected partition"/>
                    </WrapPanel>
                </DockPanel>
            </Border>

            <Border Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <ListView ItemsSource="{Binding Partitions}"
                              SelectedItem="{Binding SelectedPartition}"
                              BorderThickness="0"
                              Background="Transparent"
                              FontSize="13"
                              AutomationProperties.Name="Partition table">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                                <EventSetter Event="PreviewMouseRightButtonDown" Handler="OnPartitionRowRightClick"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Create partition" Click="OnCreate"/>
                                <Separator/>
                                <MenuItem Header="Delete partition"
                                          Command="{Binding PlacementTarget.DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="Format partition" Click="OnFormat"/>
                                <MenuItem Header="Resize partition" Click="OnResize"/>
                                <MenuItem Header="Extend partition"
                                          Command="{Binding PlacementTarget.DataContext.ExtendCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="Split partition" Click="OnSplit"/>
                                <MenuItem Header="Change drive letter" Click="OnChangeLetter"/>
                                <Separator/>
                                <MenuItem Header="Set active"
                                          Command="{Binding PlacementTarget.DataContext.SetActiveCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="Hide or unhide"
                                          Command="{Binding PlacementTarget.DataContext.HideCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="#" Width="44" DisplayMemberBinding="{Binding PartitionNumber}"/>
                                <GridViewColumn Header="Letter" Width="72" DisplayMemberBinding="{Binding LetterDisplay}"/>
                                <GridViewColumn Header="Label" Width="140" DisplayMemberBinding="{Binding Label}"/>
                                <GridViewColumn Header="Size" Width="104" DisplayMemberBinding="{Binding SizeText}"/>
                                <GridViewColumn Header="Free" Width="104" DisplayMemberBinding="{Binding FreeText}"/>
                                <GridViewColumn Header="Type" Width="100" DisplayMemberBinding="{Binding Type}"/>
                                <GridViewColumn Header="File System" Width="108" DisplayMemberBinding="{Binding FileSystem}"/>
                                <GridViewColumn Header="Details" Width="260" DisplayMemberBinding="{Binding Details}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <TextBlock Text="Select Refresh to load disks, then choose a disk to review its partition layout."
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateText}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Partitions.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
        </DockPanel>

        <Border Style="{StaticResource BusyOverlay}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Working"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="PartitionPilot is querying disks and applying the requested operation."
                           Style="{StaticResource CaptionText}"
                           Margin="0,6,0,0"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
