<UserControl x:Class="PartitionPilot.Views.DiskCloningView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <DockPanel IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
            <Border DockPanel.Dock="Top" Style="{StaticResource PanelCard}" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Disk Cloning" Style="{StaticResource PageTitleText}"/>
                        <TextBlock Text="Create disk images (WIM/VHDX) and restore them to target disks."
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource ToolbarButton}"
                            AutomationProperties.Name="Refresh disk list"/>
                </Grid>
            </Border>

            <Border DockPanel.Dock="Top" Margin="0,0,0,10">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource EmptyStatePanel}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DriveLetters.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="No cloning targets loaded" Style="{StaticResource EmptyStateTitle}"/>
                    <TextBlock Text="Refresh to load source volumes and target disks before creating or restoring an image."
                               Style="{StaticResource EmptyStateText}"
                               Margin="0"/>
                </StackPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <WrapPanel>
                    <GroupBox Header="Create Image" Style="{StaticResource ToolGroup}">
                        <StackPanel>
                            <TextBlock Text="Capture a volume to a WIM or VHDX file."
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Source Volume" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding DriveLetters}"
                                      SelectedItem="{Binding SelectedSourceDrive}"
                                      Height="34" Margin="0,0,0,10"
                                      AutomationProperties.Name="Source volume"/>
                            <TextBlock Text="Image Path" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                            <DockPanel Margin="0,0,0,10">
                                <Button DockPanel.Dock="Right" Content="Browse"
                                        Command="{Binding BrowseImageCommand}"
                                        Style="{StaticResource ToolbarButton}"
                                        Margin="6,0,0,0"
                                        AutomationProperties.Name="Browse image save path"/>
                                <TextBox Text="{Binding ImagePath, UpdateSourceTrigger=PropertyChanged}"
                                         Height="34"
                                         AutomationProperties.Name="Image file path"/>
                            </DockPanel>
                            <TextBlock Text="{Binding ImagePreflightSummary}"
                                       Style="{StaticResource CaptionText}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"
                                       AutomationProperties.Name="Image destination preflight"/>
                            <Button Content="Create Image"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding CreateImageCommand}"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="Create disk image"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Restore Image" Style="{StaticResource ToolGroup}">
                        <StackPanel>
                            <TextBlock Text="Apply a WIM or VHDX image to a target disk. All data on the target will be destroyed."
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,0,0,10"/>
                            <Border Style="{StaticResource DangerNoticePanel}">
                                <TextBlock Text="Restore writes to the selected target disk and replaces its contents."
                                           Style="{StaticResource CaptionText}"
                                           Foreground="{DynamicResource DangerBtnFgBrush}"/>
                            </Border>
                            <TextBlock Text="Image File" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                            <DockPanel Margin="0,0,0,10">
                                <Button DockPanel.Dock="Right" Content="Browse"
                                        Command="{Binding BrowseRestoreImageCommand}"
                                        Style="{StaticResource ToolbarButton}"
                                        Margin="6,0,0,0"
                                        AutomationProperties.Name="Browse restore image"/>
                                <TextBox Text="{Binding RestoreImagePath, UpdateSourceTrigger=PropertyChanged}"
                                         Height="34"
                                         AutomationProperties.Name="Restore image file path"/>
                            </DockPanel>
                            <TextBlock Text="Target Disk" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding AllDisks}"
                                      SelectedItem="{Binding SelectedTargetDisk}"
                                      ItemTemplate="{StaticResource DiskInfoComboTemplate}"
                                      Height="34" Margin="0,0,0,10"
                                      AutomationProperties.Name="Target disk"/>
                            <Button Content="Restore Image"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding RestoreImageCommand}"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="Restore disk image"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Sector Clone" Style="{StaticResource ToolGroup}">
                        <StackPanel>
                            <TextBlock Text="Copy every sector from a source disk to a destination disk. Creates an exact byte-for-byte duplicate."
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,0,0,10"/>
                            <Border Style="{StaticResource DangerNoticePanel}">
                                <TextBlock Text="Sector clone overwrites ALL data on the destination disk. The destination must be at least as large as the source."
                                           Style="{StaticResource CaptionText}"
                                           Foreground="{DynamicResource DangerBtnFgBrush}"/>
                            </Border>
                            <TextBlock Text="Source Disk" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding AllDisks}"
                                      SelectedItem="{Binding CloneSourceDisk}"
                                      ItemTemplate="{StaticResource DiskInfoComboTemplate}"
                                      Height="34" Margin="0,0,0,10"
                                      AutomationProperties.Name="Clone source disk"/>
                            <TextBlock Text="Destination Disk" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding AllDisks}"
                                      SelectedItem="{Binding CloneDestDisk}"
                                      ItemTemplate="{StaticResource DiskInfoComboTemplate}"
                                      Height="34" Margin="0,0,0,10"
                                      AutomationProperties.Name="Clone destination disk"/>
                            <TextBlock Text="{Binding CloneSizeSummary}"
                                       Style="{StaticResource CaptionText}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"
                                       AutomationProperties.Name="Clone size summary"/>
                            <TextBlock Text="{Binding CloneProgressText}"
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,0,0,6"
                                       AutomationProperties.Name="Clone progress"/>
                            <ProgressBar Value="{Binding CloneProgressPercent}"
                                         Maximum="100"
                                         Height="4"
                                         Foreground="{DynamicResource PrimaryBrush}"
                                         Background="{DynamicResource BorderBrush}"
                                         BorderThickness="0"
                                         Margin="0,0,0,10"/>
                            <Button Content="Start Clone"
                                    Style="{StaticResource DangerButton}"
                                    Command="{Binding SectorCloneCommand}"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="Start sector clone"/>
                        </StackPanel>
                    </GroupBox>
                </WrapPanel>
            </ScrollViewer>
        </DockPanel>

        <Border Style="{StaticResource BusyOverlay}">
            <Border Style="{StaticResource BusyPanel}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Disk Cloning"
                               Style="{StaticResource PageTitleText}"
                               HorizontalAlignment="Center"/>
                    <ProgressBar Style="{StaticResource BusyProgress}" IsIndeterminate="True"/>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="13"
                               TextAlignment="Center"/>
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource ToolbarButton}"
                            HorizontalAlignment="Center" Margin="0,12,0,0"
                            AutomationProperties.Name="Cancel cloning operation"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
