<UserControl x:Class="PartitionPilot.Views.HexViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PartitionPilot">
    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource PanelCard}" Padding="14,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Disk" Style="{StaticResource FieldLabelText}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding Disks}" SelectedItem="{Binding SelectedDisk}"
                          ItemTemplate="{StaticResource DiskInfoComboTemplate}"
                          Height="34" MinWidth="300"
                          AutomationProperties.Name="Hex viewer disk selector"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="14,0,0,0">
                    <TextBlock Text="Sector:" Style="{StaticResource FieldLabelText}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding SectorOffset, UpdateSourceTrigger=PropertyChanged}" Width="100" Height="28"
                             VerticalContentAlignment="Center"
                             AutomationProperties.Name="Sector offset"/>
                </StackPanel>

                <Button Grid.Column="3" Content="Read" Command="{Binding GoToSectorCommand}"
                        Style="{StaticResource ToolbarButton}" Margin="6,0,0,0"
                        AutomationProperties.Name="Read sector"/>
                <Button Grid.Column="4" Content="Prev" Command="{Binding PrevSectorCommand}"
                        Style="{StaticResource ToolbarButton}" Margin="6,0,0,0"
                        AutomationProperties.Name="Previous sector"/>
                <Button Grid.Column="5" Content="Next" Command="{Binding NextSectorCommand}"
                        Style="{StaticResource ToolbarButton}" Margin="6,0,0,0"
                        AutomationProperties.Name="Next sector"/>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Style="{StaticResource PanelCard}" Padding="14,6" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusText}" Style="{StaticResource CaptionText}"
                       AutomationProperties.Name="Hex viewer status"/>
        </Border>

        <Border Style="{StaticResource Card}" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding HexText}" FontFamily="Consolas" FontSize="13"
                           Foreground="{DynamicResource TextBrush}"
                           TextWrapping="NoWrap"
                           AutomationProperties.Name="Hex dump display"/>
            </ScrollViewer>
        </Border>
    </DockPanel>
</UserControl>
