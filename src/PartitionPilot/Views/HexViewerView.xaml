<UserControl x:Class="PartitionPilot.Views.HexViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PartitionPilot">
    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource PanelCard}" Padding="14,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{local:Loc Xaml_Disk}" Style="{StaticResource FieldLabelText}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding Disks}" SelectedItem="{Binding SelectedDisk}"
                          ItemTemplate="{StaticResource DiskInfoComboTemplate}"
                          Height="34" MinWidth="300"
                          AutomationProperties.Name="{local:Loc Xaml_HexViewerDiskSelector}"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="14,0,0,0">
                    <TextBlock Text="{local:Loc Xaml_Sector}" Style="{StaticResource FieldLabelText}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding SectorOffset, UpdateSourceTrigger=PropertyChanged}" Width="100" Height="28"
                             VerticalContentAlignment="Center"
                             AutomationProperties.Name="{local:Loc Xaml_SectorOffset}"/>
                </StackPanel>

                <Button Grid.Column="3" Content="{local:Loc Xaml_Read}" Command="{Binding GoToSectorCommand}"
                        Style="{StaticResource ToolbarButton}" Margin="6,0,0,0"
                        AutomationProperties.Name="{local:Loc Xaml_ReadSector}"/>
                <Button Grid.Column="4" Content="{local:Loc Xaml_Prev}" Command="{Binding PrevSectorCommand}"
                        Style="{StaticResource ToolbarButton}" Margin="6,0,0,0"
                        AutomationProperties.Name="{local:Loc Xaml_PreviousSector}"/>
                <Button Grid.Column="5" Content="{local:Loc Xaml_Next}" Command="{Binding NextSectorCommand}"
                        Style="{StaticResource ToolbarButton}" Margin="6,0,0,0"
                        AutomationProperties.Name="{local:Loc Xaml_NextSector}"/>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Style="{StaticResource PanelCard}" Padding="14,6" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusText}" Style="{StaticResource CaptionText}"
                       AutomationProperties.Name="{local:Loc Xaml_HexViewerStatus}"/>
        </Border>

        <Border Style="{StaticResource Card}" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding HexText}" FontFamily="Consolas" FontSize="13"
                           Foreground="{DynamicResource TextBrush}"
                           TextWrapping="NoWrap"
                           AutomationProperties.Name="{local:Loc Xaml_HexDumpDisplay}"/>
            </ScrollViewer>
        </Border>
    </DockPanel>
</UserControl>
