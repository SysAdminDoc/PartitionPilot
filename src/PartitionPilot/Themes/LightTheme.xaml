<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="WindowBgColor">#F0F2F5</Color>
    <Color x:Key="PanelBgColor">#E8EAED</Color>
    <Color x:Key="CardBgColor">#FFFFFF</Color>
    <Color x:Key="CardElevatedColor">#F8F9FA</Color>
    <Color x:Key="SurfaceColor">#F3F6F9</Color>
    <Color x:Key="BorderColor">#D1D5DB</Color>
    <Color x:Key="BorderStrongColor">#9CA3AF</Color>
    <Color x:Key="TextColor">#1A1D21</Color>
    <Color x:Key="SubtextColor">#4B5563</Color>
    <Color x:Key="MutedTextColor">#9CA3AF</Color>
    <Color x:Key="PrimaryColor">#0078D4</Color>
    <Color x:Key="PrimaryPressedColor">#005EA6</Color>
    <Color x:Key="SuccessColor">#16A34A</Color>
    <Color x:Key="WarningColor">#CA8A04</Color>
    <Color x:Key="DangerColor">#DC2626</Color>
    <Color x:Key="LogBgColor">#F8F9FA</Color>
    <Color x:Key="InputBgColor">#FFFFFF</Color>
    <Color x:Key="SelectionColor">#B3D7F2</Color>
    <Color x:Key="AccentSubtleColor">#EAF6FC</Color>
    <Color x:Key="PrimarySoftColor">#E6F4FB</Color>
    <Color x:Key="SuccessSoftColor">#E8F7EF</Color>
    <Color x:Key="WarningSoftColor">#FFF7E6</Color>
    <Color x:Key="DangerSoftColor">#FEF0F0</Color>
    <Color x:Key="TableRuleColor">#E5E7EB</Color>
    <Color x:Key="BadgeBgColor">#EEF6FB</Color>
    <Color x:Key="StatusBgColor">#F8FAFC</Color>
    <Color x:Key="DialogFooterColor">#F8F9FA</Color>

    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource WindowBgColor}"/>
    <SolidColorBrush x:Key="WindowBgBrush" Color="{StaticResource WindowBgColor}"/>
    <SolidColorBrush x:Key="PanelBgBrush" Color="{StaticResource PanelBgColor}"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}"/>
    <SolidColorBrush x:Key="CardElevatedBrush" Color="{StaticResource CardElevatedColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="{StaticResource SubtextColor}"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="{StaticResource PrimaryPressedColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="LogBgBrush" Color="{StaticResource LogBgColor}"/>
    <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource InputBgColor}"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="{StaticResource SelectionColor}"/>
    <SolidColorBrush x:Key="AccentSubtleBrush" Color="{StaticResource AccentSubtleColor}"/>
    <SolidColorBrush x:Key="PrimarySoftBrush" Color="{StaticResource PrimarySoftColor}"/>
    <SolidColorBrush x:Key="SuccessSoftBrush" Color="{StaticResource SuccessSoftColor}"/>
    <SolidColorBrush x:Key="WarningSoftBrush" Color="{StaticResource WarningSoftColor}"/>
    <SolidColorBrush x:Key="DangerSoftBrush" Color="{StaticResource DangerSoftColor}"/>
    <SolidColorBrush x:Key="TableRuleBrush" Color="{StaticResource TableRuleColor}"/>
    <SolidColorBrush x:Key="BadgeBgBrush" Color="{StaticResource BadgeBgColor}"/>
    <SolidColorBrush x:Key="StatusBgBrush" Color="{StaticResource StatusBgColor}"/>
    <SolidColorBrush x:Key="DialogFooterBrush" Color="{StaticResource DialogFooterColor}"/>

    <!-- Interactive state tokens -->
    <SolidColorBrush x:Key="ItemHoverBrush" Color="#E8EAED"/>
    <SolidColorBrush x:Key="ItemSelectedBrush" Color="#D1E5F4"/>
    <SolidColorBrush x:Key="DropdownHighlightBrush" Color="#E8EAED"/>
    <SolidColorBrush x:Key="DropdownSelectedBrush" Color="#D1E5F4"/>
    <SolidColorBrush x:Key="NavHoverBrush" Color="#E0E2E5"/>
    <SolidColorBrush x:Key="HeaderBgBrush" Color="#E8EAED"/>
    <SolidColorBrush x:Key="OverlayBrush" Color="#B8F0F2F5"/>
    <SolidColorBrush x:Key="ToolbarBtnBrush" Color="#E8EAED"/>
    <SolidColorBrush x:Key="DangerBtnBgBrush" Color="#FEE2E2"/>
    <SolidColorBrush x:Key="DangerBtnFgBrush" Color="#7F1D1D"/>
    <SolidColorBrush x:Key="PrimaryBtnFgBrush" Color="#FFFFFF"/>
</ResourceDictionary>
