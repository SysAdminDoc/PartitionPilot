<Window x:Class="PartitionPilot.Dialogs.SplitPartitionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Split Partition" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Style="{StaticResource DialogWindow}">
    <Border Style="{StaticResource Card}" Margin="16">
        <StackPanel>
            <TextBlock Text="Split Partition" Style="{StaticResource SectionTitleText}" Margin="0,0,0,6"/>
            <TextBlock x:Name="txtInfo" Style="{StaticResource CaptionText}" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,14"/>

            <TextBlock Text="New partition size (GB)" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
            <TextBox x:Name="txtNewSize" Height="34" FontSize="13" Margin="0,0,0,10"
                     AutomationProperties.Name="New partition size in GB"/>

            <TextBlock Text="New drive letter" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
            <ComboBox x:Name="cmbLetter" Height="34" FontSize="13" Margin="0,0,0,10"
                      AutomationProperties.Name="New drive letter"/>

            <TextBlock Text="File system" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
            <ComboBox x:Name="cmbFS" Height="34" FontSize="13" Margin="0,0,0,10"
                      AutomationProperties.Name="File system">
                <ComboBoxItem Content="NTFS" IsSelected="True"/>
                <ComboBoxItem Content="FAT32"/>
                <ComboBoxItem Content="exFAT"/>
                <ComboBoxItem Content="ReFS"/>
            </ComboBox>

            <TextBlock Text="Volume label" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
            <TextBox x:Name="txtLabel" Height="34" FontSize="13" Margin="0,0,0,16"
                     AutomationProperties.Name="Volume label"/>

            <Border Style="{StaticResource DialogFooter}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Split" Width="96" Height="34" Style="{StaticResource PrimaryButton}"
                            IsDefault="True" Click="OnOk"/>
                    <Button Content="Cancel" Width="96" Height="34" Margin="8,0,0,0" IsCancel="True"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</Window>
