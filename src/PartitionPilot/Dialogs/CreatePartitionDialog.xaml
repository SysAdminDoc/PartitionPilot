<Window x:Class="PartitionPilot.Dialogs.CreatePartitionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Partition" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Style="{StaticResource DialogWindow}">
    <Border Style="{StaticResource Card}" Margin="16">
        <StackPanel>
            <TextBlock Text="Create Partition" Style="{StaticResource SectionTitleText}" Margin="0,0,0,6"/>
            <TextBlock Text="Use available unallocated space to create and format a new volume."
                       Style="{StaticResource CaptionText}"
                       Margin="0,0,0,14"/>

            <TextBlock Text="Available space" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
            <TextBlock x:Name="txtInfo" Foreground="{StaticResource PrimaryBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <TextBlock Text="Size (GB)" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
            <TextBox x:Name="txtSize" Height="34" FontSize="13" Margin="0,0,0,10"/>

            <TextBlock Text="Drive letter" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
            <ComboBox x:Name="cmbLetter" Height="34" FontSize="13" Margin="0,0,0,10"/>

            <TextBlock Text="File system" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
            <ComboBox x:Name="cmbFS" Height="34" FontSize="13" Margin="0,0,0,10">
                <ComboBoxItem Content="NTFS" IsSelected="True"/>
                <ComboBoxItem Content="FAT32"/>
                <ComboBoxItem Content="exFAT"/>
                <ComboBoxItem Content="ReFS"/>
            </ComboBox>

            <TextBlock Text="Volume label" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
            <TextBox x:Name="txtLabel" Height="34" FontSize="13" Margin="0,0,0,10"/>

            <CheckBox x:Name="chkQuick" Content="Quick format" IsChecked="True" Margin="0,0,0,16"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Create" Width="96" Height="34" Style="{StaticResource PrimaryButton}"
                        IsDefault="True" Click="OnOk"/>
                <Button Content="Cancel" Width="96" Height="34" Margin="8,0,0,0" IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
