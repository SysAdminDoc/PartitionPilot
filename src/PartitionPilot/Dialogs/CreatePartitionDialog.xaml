<Window x:Class="PartitionPilot.Dialogs.CreatePartitionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PartitionPilot"
        Title="{local:Loc Xaml_CreatePartition}" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Style="{StaticResource DialogWindow}">
    <Border Style="{StaticResource Card}" Margin="16">
        <StackPanel>
            <TextBlock Text="{local:Loc Xaml_CreatePartition}" Style="{StaticResource SectionTitleText}" Margin="0,0,0,6"/>
            <TextBlock Text="{local:Loc Xaml_UseAvailableUnallocatedSpaceToCreateAndFormatANewVolume}"
                       Style="{StaticResource CaptionText}"
                       Margin="0,0,0,14"/>

            <Border Style="{StaticResource NoticePanel}">
                <StackPanel>
                    <TextBlock Text="{local:Loc Xaml_AvailableSpace}" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtInfo" Foreground="{DynamicResource PrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{local:Loc Xaml_SizeGB}" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
            <TextBox x:Name="txtSize" Height="34" FontSize="13" Margin="0,0,0,10"
                     AutomationProperties.Name="{local:Loc Xaml_PartitionSizeInGB}"/>

            <TextBlock Text="{local:Loc Xaml_DriveLetter}" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
            <ComboBox x:Name="cmbLetter" Height="34" FontSize="13" Margin="0,0,0,10"
                      AutomationProperties.Name="{local:Loc Xaml_DriveLetter}"/>

            <TextBlock Text="{local:Loc Xaml_FileSystem}" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
            <ComboBox x:Name="cmbFS" Height="34" FontSize="13" Margin="0,0,0,10"
                      AutomationProperties.Name="{local:Loc Xaml_FileSystem}">
                <ComboBoxItem Content="{local:Loc Xaml_NTFS}" Tag="NTFS" IsSelected="True"/>
                <ComboBoxItem Content="{local:Loc Xaml_FAT32}" Tag="FAT32"/>
                <ComboBoxItem Content="{local:Loc Xaml_ExFAT}" Tag="exFAT"/>
                <ComboBoxItem Content="{local:Loc Xaml_ReFS}" Tag="ReFS"/>
            </ComboBox>

            <TextBlock Text="{local:Loc Xaml_VolumeLabel}" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
            <TextBox x:Name="txtLabel" Height="34" FontSize="13" Margin="0,0,0,10"
                     AutomationProperties.Name="{local:Loc Xaml_VolumeLabel}"/>

            <CheckBox x:Name="chkQuick" Content="{local:Loc Xaml_QuickFormat}" IsChecked="True" Margin="0,0,0,16"/>

            <Border Style="{StaticResource DialogFooter}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{local:Loc Create}" Width="96" Height="34" Style="{StaticResource PrimaryButton}"
                            IsDefault="True" Click="OnOk"/>
                    <Button Content="{local:Loc Cancel}" Width="96" Height="34" Margin="8,0,0,0" IsCancel="True"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</Window>
