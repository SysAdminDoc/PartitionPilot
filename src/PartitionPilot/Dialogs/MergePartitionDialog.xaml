<Window x:Class="PartitionPilot.Dialogs.MergePartitionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PartitionPilot"
        Title="{local:Loc Xaml_MergePartitions}"
        Width="480" Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Style="{StaticResource DialogWindow}"
        AutomationProperties.Name="{local:Loc Xaml_MergePartitionsDialog}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{local:Loc Xaml_MergeTwoAdjacentPartitions}"
                   Style="{StaticResource PageTitleText}" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" Text="{local:Loc Xaml_SelectTwoAdjacentPartitionsToMergeDataFromThePrimaryPartit_055a4e63}"
                   Style="{StaticResource CaptionText}" Margin="0,0,0,12" TextWrapping="Wrap"/>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{local:Loc Xaml_PrimaryPartition}" Style="{StaticResource FieldLabelText}" VerticalAlignment="Center"/>
            <ComboBox x:Name="PrimaryCombo" Grid.Column="1" Height="34"
                      DisplayMemberPath="PartitionDisplay"
                      SelectionChanged="OnPrimaryChanged"
                      AutomationProperties.Name="{local:Loc Xaml_PrimaryPartitionSelector}"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{local:Loc Xaml_PartitionToRemove}" Style="{StaticResource FieldLabelText}" VerticalAlignment="Center"/>
            <ComboBox x:Name="SecondaryCombo" Grid.Column="1" Height="34"
                      DisplayMemberPath="PartitionDisplay"
                      AutomationProperties.Name="{local:Loc Xaml_PartitionToRemoveDuringMerge}"/>
        </Grid>

        <Border Grid.Row="4" Style="{StaticResource DangerNoticePanel}" Margin="0,0,0,10">
            <TextBlock x:Name="MergeHelpText"
                       Text="{local:Loc Xaml_ThePartitionToRemoveWillBeDeletedThePrimaryPartitionWillBe_8e358bb5}"
                       Style="{StaticResource CaptionText}" TextWrapping="Wrap"
                       Foreground="{DynamicResource DangerBtnFgBrush}"/>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{local:Loc Cancel}" Style="{StaticResource SecondaryButton}" Width="80" IsCancel="True" Margin="0,0,8,0"
                    AutomationProperties.Name="{local:Loc Xaml_CancelMerge}"/>
            <Button x:Name="MergeButton" Content="{local:Loc Xaml_QueueMerge}" Style="{StaticResource DangerButton}" Width="108" Click="OnMerge"
                    AutomationProperties.Name="{local:Loc Xaml_ConfirmMerge}"/>
        </StackPanel>
    </Grid>
</Window>
