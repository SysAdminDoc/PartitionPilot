<Window x:Class="PartitionPilot.Dialogs.MergePartitionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Merge Partitions"
        Width="480" Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Style="{StaticResource DialogWindow}"
        AutomationProperties.Name="Merge partitions dialog">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Merge Two Adjacent Partitions"
                   Style="{StaticResource PageTitleText}" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" Text="Select two adjacent partitions to merge. Data from the primary partition is preserved. The secondary partition must be empty or its data will be lost."
                   Style="{StaticResource CaptionText}" Margin="0,0,0,12" TextWrapping="Wrap"/>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Primary Partition" Style="{StaticResource FieldLabelText}" VerticalAlignment="Center"/>
            <ComboBox x:Name="PrimaryCombo" Grid.Column="1" Height="34"
                      DisplayMemberPath="PartitionDisplay"
                      SelectionChanged="OnPrimaryChanged"
                      AutomationProperties.Name="Primary partition selector"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Partition to Remove" Style="{StaticResource FieldLabelText}" VerticalAlignment="Center"/>
            <ComboBox x:Name="SecondaryCombo" Grid.Column="1" Height="34"
                      DisplayMemberPath="PartitionDisplay"
                      AutomationProperties.Name="Partition to remove during merge"/>
        </Grid>

        <Border Grid.Row="4" Style="{StaticResource DangerNoticePanel}" Margin="0,0,0,10">
            <TextBlock x:Name="MergeHelpText"
                       Text="The partition to remove will be deleted. The primary partition will be extended into the freed space when the queued operation is applied."
                       Style="{StaticResource CaptionText}" TextWrapping="Wrap"
                       Foreground="{DynamicResource DangerBtnFgBrush}"/>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Width="80" IsCancel="True" Margin="0,0,8,0"
                    AutomationProperties.Name="Cancel merge"/>
            <Button x:Name="MergeButton" Content="Queue Merge" Style="{StaticResource DangerButton}" Width="108" Click="OnMerge"
                    AutomationProperties.Name="Confirm merge"/>
        </StackPanel>
    </Grid>
</Window>
