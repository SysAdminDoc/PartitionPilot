<Window x:Class="PartitionPilot.Dialogs.ResizePartitionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resize Partition" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Style="{StaticResource DialogWindow}">
    <Border Style="{StaticResource Card}" Margin="16">
        <StackPanel>
            <TextBlock Text="Resize Partition" Style="{StaticResource SectionTitleText}" Margin="0,0,0,6"/>
            <TextBlock Text="Choose a supported target size for the selected volume."
                       Style="{StaticResource CaptionText}"
                       Margin="0,0,0,14"/>

            <TextBlock Text="Current size" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
            <TextBlock x:Name="txtInfo" Foreground="{StaticResource PrimaryBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <TextBlock Text="New size (GB)" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
            <TextBox x:Name="txtSize" Height="34" FontSize="13" Margin="0,0,0,16"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Resize" Width="96" Height="34" Style="{StaticResource PrimaryButton}"
                        IsDefault="True" Click="OnOk"/>
                <Button Content="Cancel" Width="96" Height="34" Margin="8,0,0,0" IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
