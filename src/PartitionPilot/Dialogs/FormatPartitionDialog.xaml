<Window x:Class="PartitionPilot.Dialogs.FormatPartitionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PartitionPilot"
        Title="{local:Loc Xaml_FormatPartition}" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Style="{StaticResource DialogWindow}">
    <Border Style="{StaticResource Card}" Margin="16">
        <StackPanel>
            <TextBlock Text="{local:Loc Xaml_FormatPartition}" Style="{StaticResource SectionTitleText}" Margin="0,0,0,6"/>
            <Border Style="{StaticResource DangerNoticePanel}">
                <TextBlock Text="{local:Loc Xaml_FormattingReplacesTheFileSystemOnThisVolumeAndRemovesItsEx_b589b663}"
                           Style="{StaticResource CaptionText}"
                           Foreground="{DynamicResource DangerBtnFgBrush}"/>
            </Border>

            <TextBlock Text="{local:Loc Xaml_CurrentVolume}" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
            <TextBlock x:Name="txtInfo" Foreground="{DynamicResource PrimaryBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <TextBlock Text="{local:Loc Xaml_DevicePreset}" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
            <ComboBox x:Name="cmbPreset" Height="34" FontSize="13" Margin="0,0,0,10"
                      SelectionChanged="OnPresetChanged"
                      AutomationProperties.Name="{local:Loc Xaml_DevicePreset}">
                <ComboBoxItem Content="{local:Loc Xaml_Custom}" Tag="Custom" IsSelected="True"/>
                <ComboBoxItem Content="{local:Loc Xaml_CameraFAT3232KBClusters}" Tag="Camera"/>
                <ComboBoxItem Content="{local:Loc Xaml_NintendoSwitchFAT3264KBClusters}" Tag="Nintendo"/>
                <ComboBoxItem Content="{local:Loc Xaml_RaspberryPiFAT32}" Tag="Raspberry"/>
                <ComboBoxItem Content="{local:Loc Xaml_LargeUSBExFAT}" Tag="LargeUsb"/>
                <ComboBoxItem Content="{local:Loc Xaml_GeneralNTFS}" Tag="GeneralNtfs"/>
            </ComboBox>

            <TextBlock Text="{local:Loc Xaml_FileSystem}" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
            <ComboBox x:Name="cmbFS" Height="34" FontSize="13" Margin="0,0,0,10"
                      AutomationProperties.Name="{local:Loc Xaml_FileSystem}">
                <ComboBoxItem Content="{local:Loc Xaml_NTFS}" Tag="NTFS" IsSelected="True"/>
                <ComboBoxItem Content="{local:Loc Xaml_FAT32}" Tag="FAT32"/>
                <ComboBoxItem Content="{local:Loc Xaml_ExFAT}" Tag="exFAT"/>
                <ComboBoxItem Content="{local:Loc Xaml_ReFS}" Tag="ReFS"/>
            </ComboBox>

            <TextBlock Text="{local:Loc Xaml_VolumeLabel}" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
            <TextBox x:Name="txtLabel" Height="34" FontSize="13" Margin="0,0,0,10"
                     AutomationProperties.Name="{local:Loc Xaml_VolumeLabel}"/>

            <CheckBox x:Name="chkQuick" Content="{local:Loc Xaml_QuickFormat}" IsChecked="True" Margin="0,0,0,16"/>

            <Border Style="{StaticResource DialogFooter}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{local:Loc Format}" Width="96" Height="34" Style="{StaticResource DangerButton}"
                            IsDefault="True" Click="OnOk"/>
                    <Button Content="{local:Loc Cancel}" Width="96" Height="34" Margin="8,0,0,0" IsCancel="True"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</Window>
